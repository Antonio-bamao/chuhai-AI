{"code":"facebook_peer_interception","moduleCode":"facebook","spiderParams":[{"dpIndex":"1","code":"keywords","name":"请输入小组链接","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");","step":"1"},{"js":"window.location.href=  keywords;","step":"2"},{"js":"checkListData(0,1);","step":"3"}],"homeUrl":"https://www.facebook.com/","hookurls":[{"path":"https://www.facebook.com/api/graphql/","contains":"comet_sections","callbackType":"jsfunc"},{"path":"https://web.facebook.com/api/graphql/","contains":"comet_sections","callbackType":"jsfunc"}],"spiderMode":0,"name":"FB小组同行节流","sipderJson":"if (inJsonStr.indexOf('\\n') != -1) {\n    var strs = inJsonStr.split('\\n');\n    strs.forEach(str => {\n        var json = JSON.parse(str);\n        try {\n            if (json.data?.node?.group_feed?.edges) {\n                var edges = json.data.node.group_feed.edges;\n                edges.forEach(async (o) => {\n                    var data = {};\n                    if (o.node?.comet_sections?.content?.story?.actors) {\n                        var actors = o.node.comet_sections.content.story.actors;\n                        var message = '';\n                        if (o.node?.comet_sections?.content.story?.comet_sections?.message?.rich_message) {\n                            console.log('0##rich_message##')\n                            message = o.node.comet_sections.content.story.comet_sections.message.rich_message[0];\n                        } else if (o.node?.comet_sections?.content?.story?.message) {\n                            message = o.node.comet_sections.content.story.message;\n                        }\n                        data.keywords = spider.getSpiderParams(\"keywords\");\n                        data.creation_time = getTimeStr(o.node.comet_sections.context_layout.story.comet_sections.metadata[0].story.creation_time)\n                        data.actorid = actors[0].id;\n                        data.content = message.text;\n                        data.username = actors[0].name;\n                        if (data.actorid && data.content) {\n                            // console.log('data1', data);\n                            spider.postData(JSON.stringify(data));\n                        }\n                    }\n                })\n            }\n            if (json.data?.node?.comet_sections?.content?.story) {\n                var data = {};\n                var o = json.data.node.comet_sections.content.story;\n                if (o.actors && o.comet_sections?.message) {\n                    var actors = o.actors\n                    var message = '';\n                    if (o.comet_sections?.message?.rich_message) {\n                        console.log('1##rich_message##')\n                        message = o.comet_sections.message.rich_message[0];\n                    } else if (o.comet_sections?.message?.story?.message) {\n                        message = o.comet_sections.message.story.message;\n                    }\n                    data.keywords = spider.getSpiderParams(\"keywords\");\n                    if (json?.data?.node?.comet_sections?.context_layout?.story?.comet_sections?.metadata[0]?.story?.creation_time)\n                        data.creation_time = getTimeStr(json.data.node.comet_sections.context_layout.story.comet_sections.metadata[0].story.creation_time)\n                    data.actorid = actors[0].id;\n                    data.content = message.text;\n                    data.username = actors[0].name;\n                }\n                if (data.actorid && data.content) {\n                    // console.log('data2', data);\n                    spider.postData(JSON.stringify(data));\n                }\n            }\n        } catch (error) {\n            console.log(error);\n        }\n    })\n}","id":27,"fields":[{"dpIndex":"1","code":"keywords","name":"小组链接","type":"text"},{"dpIndex":"4","code":"content","name":"内容","type":"text"},{"dpIndex":"3","code":"actorid","name":"发布者ID","type":"text"},{"dpIndex":"2","code":"username","name":"发布者名称","type":"text"},{"dpIndex":"6","code":"creation_time","name":"发布时间","type":"text"},{"dpIndex":"7","code":"date","name":"采集时间","type":"text"}],"spiderAppCode":"0","displayIndex":0,"injectionjs":"function checkListData(nums, count) {\n    window.scrollTo({\n        top: document.body.scrollHeight,\n        behavior: 'smooth'\n    });\n    var proFile = document.querySelectorAll('div[role=\"feed\"]>div div[aria-posinset]');\n    if (proFile == null || proFile.lenght == 0) {\n        console.log(\"没有数据啦\");\n        spider.endTask();\n    } else {\n        if (proFile.length != nums || (nums >= proFile.length && count != 5)) {\n            if (nums >= proFile.length) {\n                count++;\n            }\n            var s = 'div[role=\"feed\"]>div div[aria-posinset]';\n            spider.toCheckDomDataWait(s, 60, function (flg) {\n                if (flg) {\n                    spider.toRunJsWaitTime(function () {\n                        console.log('proFile.length', proFile.length);\n                        checkListData(proFile.length, count);\n                    }, 5, 10);\n                } else {\n                    console.log(\"没有数据啦\");\n                    spider.endTask();\n\n                }\n            });\n        } else {\n            console.log(\"没有数据啦\");\n            spider.endTask();\n        }\n\n    }\n}\nfunction getTimeStr(timestm) {\n    var creation_time = timestm * 1000;\n    var date = new Date(creation_time);\n    var year = date.getFullYear();\n    var month = ('0' + (date.getMonth() + 1)).slice(-2);\n    var day = ('0' + date.getDate()).slice(-2);\n    var hours = ('0' + date.getHours()).slice(-2);\n    var minutes = ('0' + date.getMinutes()).slice(-2);\n    var seconds = ('0' + date.getSeconds()).slice(-2);\n    return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;\n}"}