{"code":"whatsapp_regional_collection","moduleCode":"whatsapp","spiderParams":[{"dpIndex":"1","code":"adds","name":"请选择城市地理位置","type":"GGMap"},{"dpIndex":"2","code":"keywords","name":"请输入关键词","type":"keyWords"},{"dpIndex":"4","code":"isfilter","name":"是否过滤空线索","type":"yesOrNo"},{"dpIndex":"3","code":"get_range","requiredSign":"","name":"采集范围","type":"gps_range"}],"steps":[{"js":"var ggSite = spider.getSpiderParams(\"adds\");\nconsole.log(\"ggSite ==\" + ggSite);\nspider.doHref(ggSite);\nspider.wait(5);","step":"1"},{"js":"var ggSite = spider.getSpiderParams(\"adds\");\nconsole.log(\"ggSite ==\" + ggSite);\nspider.toCheckDomDataWait('#recaptcha', 7, function (flg) {\n    if (flg) {\n        checkGoogleVerifyIframe();\n    } \n});\n","step":"4"},{"js":"var isfilter = spider.getSpiderParams(\"isfilter\");\nvar nums = spider.getSpiderParams(\"nums\");\nif (nums != 'nums') nums = nums.split(\"/\");\nelse nums = []\nisfilter = isfilter == \"Y\" ? true : false;\nspider.toCheckDomDataWait('div[role=\"feed\"]>div:not([class])', 120, async function (flg) {\n    if (flg) {\n        // checkGooglePageData(0, 1, isfilter, nums);\n        await checkGooglePageData(0, 1, isfilter);\n    }  else {\n        console.log(\"没有数据啦11\");\n        spider.endTask();\n    }\n});","step":"5"}],"homeUrl":"https://www.google.com","hookurls":[{"path":""}],"spiderMode":0,"name":"WS地区采集","id":41,"fields":[{"dpIndex":"1","code":"keywords","name":"关键词","type":"text"},{"dpIndex":"8","code":"city","name":"城市","type":"text"},{"dpIndex":"3","code":"name","name":"名称","type":"text"},{"dpIndex":"0","code":"phone","name":"线索","type":"text"},{"dpIndex":"6","code":"links","name":"网站","type":"text_url"},{"dpIndex":"7","code":"oloc","name":"oloc","type":"text"},{"dpIndex":"10","code":"date","name":"采集时间","type":"text"},{"dpIndex":"9","code":"adds","name":"位置","type":"text"}],"spiderAppCode":"0","displayIndex":1,"injectionjs":"async function extractBusinessInfo(htmlString, index) {\n    const parser = new DOMParser();\n    const doc = parser.parseFromString(htmlString, 'text/html');\n    \n    // 提取商家名称\n    const nameElement = doc.querySelector('.qBF1Pd.fontHeadlineSmall');\n    const name = nameElement ? nameElement.textContent.trim() : null;\n    \n    // 提取电话\n    const phoneElement = doc.querySelector('.UsdlK');\n    const phone = phoneElement ? phoneElement.textContent.trim() : null;\n    \n    // 提取网站链接\n\n    document.querySelectorAll('a.hfpxzc')[index]?.click();\n    await wait(1500)\n    spider.wait(1)\n    const linkElement = document.querySelector('a[data-tooltip=\"打开网站\"]');\n    const website = linkElement ? linkElement.getAttribute('href') : null;\n    document.querySelector('button[data-disable-idom=\"true\"]')?.click()\n    await wait(900)\n\n    // 提取地址信息\n    const addressElements = doc.querySelectorAll('.W4Efsd span span');\n    let address = null;\n    let category = null;\n    \n    if (addressElements.length >= 2) {\n        // 第一个通常是类别\n        category = addressElements[0]?.textContent.trim() || null;\n        \n        // 第二个通常是地址\n        if (addressElements.length > 1) {\n            address = addressElements[1]?.textContent.trim() || null;\n        }\n    }\n    \n    // 提取评分信息\n    const ratingElement = doc.querySelector('.MW4etd');\n    const rating = ratingElement ? parseFloat(ratingElement.textContent.trim()) : null;\n    \n    const reviewsElement = doc.querySelector('.UY7F9');\n    const reviews = reviewsElement ? reviewsElement.textContent.trim() : null;\n    \n    // 提取营业状态\n    const statusElement = doc.querySelector('.W4Efsd span span span');\n    const openingStatus = statusElement ? statusElement.textContent.trim() : null;\n    \n    // 提取评论\n    const reviewElement = doc.querySelector('.ah5Ghc span');\n    const review = reviewElement ? reviewElement.textContent.trim() : null;\n    \n    // 提取图片链接\n    const imgElement = doc.querySelector('img[src*=\"googleusercontent.com\"]');\n    const imageUrl = imgElement ? imgElement.getAttribute('src') : null;\n    \n    return {\n        name: name,\n        phone: phone,\n        website: website,\n        address: address,\n        category: category,\n        rating: rating,\n        reviews: reviews,\n        openingStatus: openingStatus,\n        review: review,\n        imageUrl: imageUrl\n    };\n}\n \n\nasync function checkGooglePageData(index, count, isfilter) {\n    var feedDoc = document.querySelectorAll('div[role=\"feed\"]>div:not([class])');\n    console.log('feedDoc ', feedDoc);\n    if (feedDoc != null && feedDoc.length > 0) {\n        if (index == feedDoc.length - 1 && count > 4) {\n            console.log('没有数据了1');\n            spider.endTask();\n        }\n        if (index >= feedDoc.length - 1) {\n            count++;\n        }\n        var divFeed = document.querySelector('div[role=\"feed\"]');\n        var docIndex = index;\n        var height = feedDoc[docIndex].scrollHeight + docIndex * 250;\n        divFeed.scrollTo({\n            top: height,\n            behavior: 'smooth'\n        });\n        for (; index < feedDoc.length - 1; index++) {\n            if (feedDoc[index].childNodes && feedDoc[index].childNodes.length > 0\n                && feedDoc[index].childNodes[0].childNodes) {\n                // console.log('<a>', feedDoc[index].childNodes[0].childNodes[0]);\n\n                var aHref = feedDoc[index].childNodes[0].childNodes[0].href;\n\n                console.log(\"feedDoc[\"+index+\"]\",feedDoc[index]);\n\n                const businessInfo = await extractBusinessInfo(feedDoc[index].innerHTML, index);\n                console.log(businessInfo);\n\n                            var data = {};\n                                data.keywords = spider.getSpiderParams(\"keywords\");\n                                data.adds = spider.getSpiderParams(\"adds\");\n                                data.links =  businessInfo.website ;\n                                    data.name = businessInfo.name;\n                                    data.oloc = businessInfo.category;\n \n                                    data.phone  = businessInfo.phone ;\n                                    //data.category  = businessInfo.category;\n                                    //  data.description  = businessInfo.description ;\n\n                                    if (data.name != null) {\n                                            if (isfilter) {\n                                                if (data.phone) {\n                                                    spider.postData(JSON.stringify(data));\n                                                }\n                                            } else\n                                                spider.postData(JSON.stringify(data));\n                                        }\n\n\n\n                 \n\n            } else {\n                console.log('没有数据了2');\n                spider.endTask();\n            }\n        }\n\n        spider.toRunJsWaitTime(function () {\n            checkGooglePageData(index, count, isfilter);\n        }, 8, 16);\n    } else {\n        console.log('没有数据了3');\n        spider.endTask();\n    }\n}\n\n\nfunction checkGoogleVerifyIframe() {\n    if (document.querySelector('#recaptcha') || document.querySelector('#recaptcha-demo')) {\n        mijava.stopIntervalRunJs();\n        console.log('出现验证框');\n        // 1.触发验证\n        spider.toCheckDom('iframe[title=\"reCAPTCHA\"]', 10, function (flg) {\n            if (flg) {\n                var docBtn = onloadIframe('iframe[title=\"reCAPTCHA\"]', 0)\n                docBtn.querySelector(\"#rc-anchor-container\").click();\n                setTimeout(() => {\n                    startVerify();\n                }, 5000)\n            } else {\n                // spider.endTask();\n            }\n        });\n\n    } else {\n        console.log('正常运行')\n    }\n}\n\n\n\n// 图转base64\nfunction convertImageToBase64(url, callback) {\n    var xhr = new XMLHttpRequest();\n    xhr.onload = function () {\n        var reader = new FileReader();\n        reader.onloadend = function () {\n            callback(reader.result.split(',')[1]); // 分割结果获取Base64部分\n        }\n        reader.readAsDataURL(xhr.response);\n    };\n    xhr.open('GET', url);\n    xhr.responseType = 'blob';\n    xhr.send();\n}\n\n\n\n// 检测选中图片模块\nfunction checkImgSelected(doc) {\n    var imgs = doc.querySelectorAll('#rc-imageselect-target table td');\n    var i = 0;\n    var res = [];\n    imgs.forEach((img, i) => {\n        var selected = img.classList.contains('rc-imageselect-tileselected');\n        if (selected) {\n            res.push(i++);\n        }\n    })\n    return res;\n}\n\nfunction onloadIframe(iframeSelect, index) {\n    spider.wait(3)\n    var iframe = document.querySelectorAll(iframeSelect)[index]\n    var iframe_contentDocument = iframe?.contentDocument\n    return iframe_contentDocument;\n}\n\n\n// 点击图片模块\nfunction clickImgModule(locations, doc, qid, callback) {\n    let remaining = locations.length;\n\n    for (let i = 0; i < locations.length; i++) {\n        setTimeout(() => {\n            verifySingleCaptcha(doc, locations[i], qid, () => {\n                remaining--;\n                if (remaining === 0) {\n                    callback();\n                }\n            });\n        }, i * 1700);\n    }\n\n}\n\n\n\n// 点击单图\nfunction verifySingleCaptcha(doc, index, qid, callback) {\n    var imgs = doc.querySelectorAll('#rc-imageselect-target table td');\n    var img = imgs[index];\n    img.click();\n    var selected = img.classList.contains('rc-imageselect-tileselected');\n    if (!selected) { //点击过但没有选中，说明是二次验证\n        setTimeout(() => {\n            var doc = document?.querySelectorAll('iframe[title^=\"recaptcha\"]')[0]?.contentDocument\n            if (!doc) doc = document.querySelectorAll('iframe[title^=\"reCAPTCHA 验证\"]')[0]?.contentDocument\n            var singleImg = doc.querySelectorAll('#rc-imageselect-target table td')[index].querySelector('img');\n            var src = singleImg.src;\n            console.log(src)\n            convertImageToBase64(src, base64 => {\n                mijava.creatGoogleCRTask(base64, qid, r => {\n                    var res = JSON.parse(r);\n                    console.log('singleImg -> ', r);\n                    if (res.solution.hasObject) {\n                        verifySingleCaptcha(doc, index, qid, callback);\n                    } else {\n                        callback();\n                    }\n                })\n            });\n        }, 5000)\n    } else {\n        callback();\n    }\n}\n\nfunction startVerify() {\n    console.log(\"开采\");\n    // 2.采集图片base64，检测识别关键字\n    // 调用onloadIframe，并使用then方法处理Promise的成功情况\n    var docimg = onloadIframe('iframe[title^=\"recaptcha\"]', 0)\n    if (!docimg) {\n        docimg = document.querySelectorAll('iframe[title^=\"reCAPTCHA 验证\"]')[0]?.contentDocument\n    }\n    // console.log(res);\n    console.log(\"wait\")\n    var img = docimg.querySelector('img');\n    var src = img.src;\n    // console.log(\"fullimg -> \", src);\n\n    convertImageToBase64(src, function (base64) {\n        var keyward = docimg.querySelector(\"strong\").innerText;\n        var qid = question_id[keyward];\n        // console.log(\"qid\", qid)\n        mijava.creatGoogleCRTask(base64, qid, async r => {\n            try {\n                // 3.调用接口，返回框图index数组\n                var res = JSON.parse(r);\n                // console.log('res', res);\n                var nums = res.solution.objects;\n                console.log('nums', nums);\n                if (nums.length > 0) {\n                    // 4.点击块区图片\n                    clickImgModule(nums, docimg, qid, () => {\n                        setTimeout(() => {\n                            spider.asyncRunJs(3, \"getIsSuccessful\");\n                            docimg.querySelector('#recaptcha-verify-button').click(); // 点击验证\n                        }, 1000);\n                    });\n                } else {\n                    docimg.querySelector('#recaptcha-verify-button').click(); // 点击验证\n                }\n            } catch (e) {\n                console.log(\"error -> \", e);\n                alert(\"接口验证失败，请联系工作人员\"+e.message);\n            }\n\n        })\n    });\n\n}\n\n\n\n//检测验证是否成功\nfunction getIsSuccessful() {\n    try {\n\n        var doc = document.querySelector('iframe[title=\"reCAPTCHA\"]')?.contentDocument?.querySelector('#recaptcha-anchor')?.getAttribute('aria-checked')\n        if (doc === undefined) {\n            mijava.startIntervalRunJs(6000, \"checkGoogleVerifyIframe\")\n            // checkGooglePageData();\n            spider.asyncRunJs(3, \"checkGooglePageData\");\n        } else {\n            if (doc != \"true\") {\n                startVerify();\n            } else {\n                setTimeout(() => {\n                    mijava.startIntervalRunJs(6000, \"checkGoogleVerifyIframe\")\n                    spider.asyncRunJs(3, \"checkGooglePageData\");\n                }, 3000)\n            }\n        }\n    } catch (e) {\n        console.log(\"error -> \", e)\n    }\n}\n\nconst question_id = {\n    \"taxis\": \"/m/0pg52\",\n    \"bus\": \"/m/01bjv\",\n    \"buses\": \"/m/01bjv\",\n    \"school bus\": \"/m/02yvhj\",\n    \"motorcycles\": \"/m/04_sv\",\n    \"tractors\": \"/m/013xlm\",\n    \"chimneys\": \"/m/01jk_4\",\n    \"crosswalks\": \"/m/014xcs\",\n    \"traffic lights\": \"/m/015qff\",\n    \"bicycles\": \"/m/0199g\",\n    \"parking meters\": \"/m/015qbp\",\n    \"cars\": \"/m/0k4j\",\n    \"vehicles\": \"/m/0k4j\",\n    \"bridges\": \"/m/015kr\",\n    \"boats\": \"/m/019jd\",\n    \"palm trees\": \"/m/0cdl1\",\n    \"mountains or hills\": \"/m/09d_r\",\n    \"fire hydrant\": \"/m/01pns0\",\n    \"fire hydrants\": \"/m/01pns0\",\n    \"a fire hydrant\": \"/m/01pns0\",\n    \"stairs\": \"/m/01lynh\",\n    \"出租车\": \"/m/0pg52\",\n    \"巴士\": \"/m/01bjv\",\n    \"摩托车\": \"/m/04_sv\",\n    \"机动车\": \"/m/0k4j\",\n    \"小轿车\": \"/m/0k4j\",\n    \"拖拉机\": \"/m/013xlm\",\n    \"烟囱\": \"/m/01jk_4\",\n    \"人行横道\": \"/m/014xcs\",\n    \"红绿灯\": \"/m/015qff\",\n    \"自行车\": \"/m/0199g\",\n    \"停车计价表\": \"/m/015qbp\",\n    \"汽车\": \"/m/0k4j\",\n    \"桥\": \"/m/015kr\",\n    \"船\": \"/m/019jd\",\n    \"棕榈树\": \"/m/0cdl1\",\n    \"山\": \"/m/09d_r\",\n    \"消防栓\": \"/m/01pns0\",\n    \"楼梯\": \"/m/01lynh\",\n    \"交通工具\": \"/m/0k4j\",\n    \"公交车\": \"/m/01bjv\",\n    \"彩色玻璃\": \"/m/011y23\",\n    \"火车站\": \"/m/0py27\",\n    \"消火栓\": \"/m/01pns0\",\n    \"过街人行道\": \"/m/014xcs\",\n    \"车库门\": \"/m/08l941\",\n    \"公交站\": \"/m/01jw_1\",\n    \"停车计时器\": \"/m/015qbp\",\n    \"丘陵\": \"/m/09d_r\",\n    \"车辆\": \"/m/0k4j\",\n    \"公共汽车\": \"/m/01bjv\",\n    \"交通灯\": \"/m/015qff\",\n    \"停车咪表\": \"/m/015qbp\"\n}\n\nfunction wait(ms) {\n   console.debug('同步等待...', ms);\n   return new Promise(resolve => setTimeout(resolve, ms));\n}"}