{"code":"whatsapp_group_lists","moduleCode":"whatsapp","spiderParams":[{"dpIndex":"1","code":"googSite","name":"请选择谷歌站点","type":"googleSite"},{"dpIndex":"3","code":"pltCode","name":"请选择相关平台","type":"platform"},{"dpIndex":"4","code":"keywords","name":"请输入关键词","type":"keyWords"}],"steps":[{"js":"var ggSite = spider.getSpiderParams(\"googSite\");\nconsole.log(\"ggSite ==\"+ggSite );\nvar ggURl = \"https://www.\"+ggSite +\"/ncr\";\nspider.doHref(ggURl );\n\t\t","step":"1"},{"js":"var ptxt = \"policies.google.com/technologies/cookies\";\nspider.doCheckHtmlTextContains(ptxt,30,flg=>{\n   if(flg){\n      spider.toClick('document.querySelectorAll(\"button\")[document.querySelectorAll(\"button\").length-1]',10);\n    }\n});\n","step":"2"},{"js":"spider.toCheckDom(\"textarea[name='q']\",30,function(flg){\n\tif(flg){ \t\t\n\t\tvar pltCode= spider.getSpiderParams(\"pltCode\");\n\t\t\n\t\tvar keywords= spider.getSpiderParams(\"keywords\");\n\t\tvar allkeywords=\"site:\"+pltCode+\" \"+keywords+\" intext:chat.whatsapp.com\";  \n\t\tconsole.log(\"allkeywords==\"+allkeywords);\n\t\tsetZWBrsValue(\"textarea[name='q']\",allkeywords,true);\n \n\t}else{\n\t\tspider.endTask(); \n\t}\n});","step":"3"},{"js":"spider.toCheckDom(\"form[role='search'] input[role='button']\",30,function(flg){\n\tif(flg){ \t\t\n\t\tdocument.querySelector(\"form[role='search'] input[role='button']\").click(); \n\t}else{\n\t\tspider.endTask(); \n\t}\n});","step":"4"},{"js":"mijava.startIntervalRunJs(6000,\"checkGoogleVerifyIframe\")\nspider.toCheckDom(\"div[id='main']\", 120, function (flg) {\n    if (flg) {\n        checkGooglePageData();\n    }\n});","step":"5"}],"homeUrl":"https://www.google.com","hookurls":[{"path":""}],"spiderMode":0,"name":"WS小组采集","id":25,"fields":[{"dpIndex":"1","code":"googSite","name":"站点","type":"text"},{"dpIndex":"2","code":"pltCode","name":"来源平台","type":"text"},{"dpIndex":"3","code":"keywords","name":"相关关键词","type":"text"},{"dpIndex":"6","code":"group_link","name":"小组链接","type":"text_url"},{"dpIndex":"7","code":"url","name":"网址","type":"text_url"},{"dpIndex":"8","code":"date","name":"采集时间","type":"text"}],"spiderAppCode":"0","displayIndex":1,"injectionjs":"function checkGoogleVerifyIframe() {\n    if (document.querySelector('#recaptcha') || document.querySelector('#recaptcha-demo')) {\n        mijava.stopIntervalRunJs();\n        console.log('出现验证框');\n        // 1.触发验证\n        spider.toCheckDom('iframe[title=\"reCAPTCHA\"]', 10, function (flg) {\n            if (flg) {\n                var docBtn = onloadIframe('iframe[title=\"reCAPTCHA\"]', 0)\n                docBtn.querySelector(\"#rc-anchor-container\").click();\n                setTimeout(() => {\n                    startVerify();\n                }, 5000)\n            } else {\n                // spider.endTask();\n            }\n        });\n\n    } else {\n        console.log('正常运行')\n    }\n}\n\n\n\n// 图转base64\nfunction convertImageToBase64(url, callback) {\n    var xhr = new XMLHttpRequest();\n    xhr.onload = function () {\n        var reader = new FileReader();\n        reader.onloadend = function () {\n            callback(reader.result.split(',')[1]); // 分割结果获取Base64部分\n        }\n        reader.readAsDataURL(xhr.response);\n    };\n    xhr.open('GET', url);\n    xhr.responseType = 'blob';\n    xhr.send();\n}\n\n\n\n// 检测选中图片模块\nfunction checkImgSelected(doc) {\n    var imgs = doc.querySelectorAll('#rc-imageselect-target table td');\n    var i = 0;\n    var res = [];\n    imgs.forEach((img, i) => {\n        var selected = img.classList.contains('rc-imageselect-tileselected');\n        if (selected) {\n            res.push(i++);\n        }\n    })\n    return res;\n}\n\nfunction onloadIframe(iframeSelect, index) {\n    spider.wait(3)\n    var iframe = document.querySelectorAll(iframeSelect)[index]\n    var iframe_contentDocument = iframe?.contentDocument\n    return iframe_contentDocument;\n}\n\n\n// 点击图片模块\nfunction clickImgModule(locations, doc, qid, callback) {\n    let remaining = locations.length;\n\n    for (let i = 0; i < locations.length; i++) {\n        setTimeout(() => {\n            verifySingleCaptcha(doc, locations[i], qid, () => {\n                remaining--;\n                if (remaining === 0) {\n                    callback();\n                }\n            });\n        }, i * 1700);\n    }\n\n}\n\n\n\n// 点击单图\nfunction verifySingleCaptcha(doc, index, qid, callback) {\n    var imgs = doc.querySelectorAll('#rc-imageselect-target table td');\n    var img = imgs[index];\n    img.click();\n    var selected = img.classList.contains('rc-imageselect-tileselected');\n    if (!selected) { //点击过但没有选中，说明是二次验证\n        setTimeout(() => {\n            var doc = document?.querySelectorAll('iframe[title^=\"recaptcha\"]')[0]?.contentDocument\n            if (!doc) doc = document.querySelectorAll('iframe[title^=\"reCAPTCHA 验证\"]')[0]?.contentDocument\n            var singleImg = doc.querySelectorAll('#rc-imageselect-target table td')[index].querySelector('img');\n            var src = singleImg.src;\n            console.log(src)\n            convertImageToBase64(src, base64 => {\n                mijava.creatGoogleCRTask(base64, qid, r => {\n                    var res = JSON.parse(r);\n                    console.log('singleImg -> ', r);\n                    if (res.solution.hasObject) {\n                        verifySingleCaptcha(doc, index, qid, callback);\n                    } else {\n                        callback();\n                    }\n                })\n            });\n        }, 5000)\n    } else {\n        callback();\n    }\n}\n\nfunction startVerify() {\n    console.log(\"开采\");\n    // 2.采集图片base64，检测识别关键字\n    // 调用onloadIframe，并使用then方法处理Promise的成功情况\n    var docimg = onloadIframe('iframe[title^=\"recaptcha\"]', 0)\n    if (!docimg) {\n        docimg = document.querySelectorAll('iframe[title^=\"reCAPTCHA 验证\"]')[0]?.contentDocument\n    }\n    // console.log(res);\n    console.log(\"wait\")\n    var img = docimg.querySelector('img');\n    var src = img.src;\n    // console.log(\"fullimg -> \", src);\n\n    convertImageToBase64(src, function (base64) {\n        var keyward = docimg.querySelector(\"strong\").innerText;\n        var qid = question_id[keyward];\n        // console.log(\"qid\", qid)\n        mijava.creatGoogleCRTask(base64, qid, async r => {\n            try {\n                // 3.调用接口，返回框图index数组\n                var res = JSON.parse(r);\n                // console.log('res', res);\n                var nums = res.solution.objects;\n                console.log('nums', nums);\n                if (nums.length > 0) {\n                    // 4.点击块区图片\n                    clickImgModule(nums, docimg, qid, () => {\n                        setTimeout(() => {\n                            spider.asyncRunJs(3, \"getIsSuccessful\");\n                            docimg.querySelector('#recaptcha-verify-button').click(); // 点击验证\n                        }, 1000);\n                    });\n                } else {\n                    docimg.querySelector('#recaptcha-verify-button').click(); // 点击验证\n                }\n            } catch (e) {\n                console.log(\"error -> \", e);\n                alert(\"接口验证失败，请联系工作人员\"+e.message);\n            }\n\n        })\n    });\n\n}\n\n\n\n//检测验证是否成功\nfunction getIsSuccessful() {\n    try {\n\n        var doc = document.querySelector('iframe[title=\"reCAPTCHA\"]')?.contentDocument?.querySelector('#recaptcha-anchor')?.getAttribute('aria-checked')\n        if (doc === undefined) {\n            mijava.startIntervalRunJs(6000, \"checkGoogleVerifyIframe\")\n            // checkGooglePageData();\n            spider.asyncRunJs(7, \"checkGooglePageData\");\n        } else {\n            if (doc != \"true\") {\n                startVerify();\n            } else {\n                setTimeout(() => {\n                    mijava.startIntervalRunJs(6000, \"checkGoogleVerifyIframe\")\n                    spider.asyncRunJs(7, \"checkGooglePageData\");\n                }, 3000)\n            }\n        }\n    } catch (e) {\n        console.log(\"error -> \", e)\n    }\n}\n\nconst question_id = {\n    \"taxis\": \"/m/0pg52\",\n    \"bus\": \"/m/01bjv\",\n    \"buses\": \"/m/01bjv\",\n    \"school bus\": \"/m/02yvhj\",\n    \"motorcycles\": \"/m/04_sv\",\n    \"tractors\": \"/m/013xlm\",\n    \"chimneys\": \"/m/01jk_4\",\n    \"crosswalks\": \"/m/014xcs\",\n    \"traffic lights\": \"/m/015qff\",\n    \"bicycles\": \"/m/0199g\",\n    \"parking meters\": \"/m/015qbp\",\n    \"cars\": \"/m/0k4j\",\n    \"vehicles\": \"/m/0k4j\",\n    \"bridges\": \"/m/015kr\",\n    \"boats\": \"/m/019jd\",\n    \"palm trees\": \"/m/0cdl1\",\n    \"mountains or hills\": \"/m/09d_r\",\n    \"fire hydrant\": \"/m/01pns0\",\n    \"fire hydrants\": \"/m/01pns0\",\n    \"a fire hydrant\": \"/m/01pns0\",\n    \"stairs\": \"/m/01lynh\",\n    \"出租车\": \"/m/0pg52\",\n    \"巴士\": \"/m/01bjv\",\n    \"摩托车\": \"/m/04_sv\",\n    \"机动车\": \"/m/0k4j\",\n    \"小轿车\": \"/m/0k4j\",\n    \"拖拉机\": \"/m/013xlm\",\n    \"烟囱\": \"/m/01jk_4\",\n    \"人行横道\": \"/m/014xcs\",\n    \"红绿灯\": \"/m/015qff\",\n    \"自行车\": \"/m/0199g\",\n    \"停车计价表\": \"/m/015qbp\",\n    \"汽车\": \"/m/0k4j\",\n    \"桥\": \"/m/015kr\",\n    \"船\": \"/m/019jd\",\n    \"棕榈树\": \"/m/0cdl1\",\n    \"山\": \"/m/09d_r\",\n    \"消防栓\": \"/m/01pns0\",\n    \"楼梯\": \"/m/01lynh\",\n    \"交通工具\": \"/m/0k4j\",\n    \"公交车\": \"/m/01bjv\",\n    \"彩色玻璃\": \"/m/011y23\",\n    \"火车站\": \"/m/0py27\",\n    \"消火栓\": \"/m/01pns0\",\n    \"过街人行道\": \"/m/014xcs\",\n    \"车库门\": \"/m/08l941\",\n    \"公交站\": \"/m/01jw_1\",\n    \"停车计时器\": \"/m/015qbp\",\n    \"丘陵\": \"/m/09d_r\",\n    \"车辆\": \"/m/0k4j\",\n    \"公共汽车\": \"/m/01bjv\",\n    \"交通灯\": \"/m/015qff\",\n    \"停车咪表\": \"/m/015qbp\"\n}\n\nfunction procGetPhoneNumbers(text) {\n    if (null == text || text == \"\") return [];\n    text = text.replace(/[\\s\\n\\r()_-]/g, '');\n    let regex = /\\d{8,}/g;\n    let phoneNumbers = text.match(regex) || [];\n\n    return phoneNumbers;\n}\nfunction procGetLinks(text) {\n    if (null == text || text == \"\") return [];\n    //text = text.replace(/[\\s\\n\\r()_-]/g, '');\n    //let regex = \"(https?|ftp|file|http)://[-A-Za-z0-9+&@#/%?=~_|!:,.;]+[-A-Za-z0-9+&@#/%=~_|]\";\n    let regex = /https?:\\/\\/chat\\.whatsapp\\.\\s?com\\/[a-zA-Z0-9]{22}/g;\n    let links = (text.match(regex) || []).map(link => link.replace(/\\s+/g, ''));\n\n    return links;\n\n}\nfunction procFBItems() {\n    var googSite = spider.getSpiderParams(\"googSite\");\n    var pltCode = spider.getSpiderParams(\"pltCode\");\n    var areaCode = spider.getSpiderParams(\"areaCode\");\n    var keywords = spider.getSpiderParams(\"keywords\");\n\n    try {\n        document.querySelectorAll(\"a[ping*='/url'][aria-label]\").forEach(a => {\n            var item = a.parentNode.parentNode;\n            var title = \"\";\n            if (item.querySelector(\"span[jscontroller] a h3\")) {\n                title = item.querySelector(\"span[jscontroller] a h3\").textContent;\n            }\n            var url = \"\";\n            if (item.querySelector(\"span[jscontroller] a\")) {\n                url = item.querySelector(\"span[jscontroller] a\").href;\n            }\n            var body = item.querySelector(\"div[jscontroller][jsaction*=': '][jsshadow]\");\n            var subbody = \"\";\n            if (body) {\n                subbody = body.textContent;\n            } else {\n                subbody = item.querySelector(\"div\").textContent;\n            }\n\n\n\n            var data = {};\n            data.title = title;\n            data.url = url;\n            data.body = subbody;\n            data.googSite = googSite;\n            data.keywords = keywords;\n            data.pltCode = pltCode;\n            data.phone = procGetPhoneNumbers(subbody).join(',');\n\n            var group_link = procGetLinks(subbody);\n            if (group_link && group_link.length > 0) {\n                data.group_link = group_link.join('       ');\n                datas.push(data);\n                spider.postData(JSON.stringify(data));\n            }\n\n\n\n            item.remove();\n        });\n    } catch (e) { console.log(e) }\n\n}\nconst ITEMS = \"div[id='center_col'] div[data-ved] div[data-snc],div[id='center_col'] div.MjjYud div[class = 'g PmEWq']>div>div,div[id='center_col'] div.MjjYud div[jscontroller='rTuANe']\"\n\nfunction procBody() {\n    var datas = [];\n    var googSite = spider.getSpiderParams(\"googSite\");\n    var pltCode = spider.getSpiderParams(\"pltCode\");\n    var areaCode = spider.getSpiderParams(\"areaCode\");\n    var keywords = spider.getSpiderParams(\"keywords\");\n\n    try {\n        var items = document.querySelectorAll(ITEMS);\n        for (var i = 0; i < items.length; i++) {\n            var jsaction = items[i];\n            if (jsaction) {\n                if (jsaction.querySelector(\"div[data-snhf='0']  h3\")) {\n                    console.log(\"*********************\" + i + \"*************************************\");\n                    var title = jsaction.querySelector(\"div[data-snhf='0']  h3\").textContent;\n                    var url = jsaction.querySelector(\"div[data-snhf='0']  a[href]\").getAttribute(\"href\");\n                    var subbody = \"\";\n                    if (jsaction.querySelector(\"div[data-sncf='1']\")) {\n                        subbody = jsaction.querySelector(\"div[data-sncf='1']\").textContent;\n                    } else if (jsaction.querySelector(\"div[data-sncf='2']\")) {\n                        subbody = jsaction.querySelector(\"div[data-sncf='2']\").textContent;\n                    }\n                    var data = {};\n                    data.title = title;\n                    data.url = url;\n                    data.body = subbody;\n                    data.googSite = googSite;\n                    data.keywords = keywords;\n                    data.pltCode = pltCode;\n                    data.phone = procGetPhoneNumbers(subbody).join(',');\n                    var group_link = procGetLinks(subbody);\n                    if (group_link && group_link.length > 0) {\n                        data.group_link = group_link.join('       ');\n                        datas.push(data);\n                        spider.postData(JSON.stringify(data));\n                    }\n\n                }\n                else if (jsaction.querySelector(\"div.nhaZ2c  h3\")) {\n                    console.log(\"*v********************\" + i + \"*************************************\");\n                    var title = jsaction.querySelector(\"div.nhaZ2c  h3\").textContent;\n                    var url = jsaction.querySelector(\"div.nhaZ2c  a[href]\").getAttribute(\"href\");\n                    var subbody = jsaction.querySelector(\"div.ITZIwc\").textContent;\n                    var data = {};\n                    data.title = title;\n                    data.url = url;\n                    data.body = subbody;\n                    data.googSite = googSite;\n                    data.keywords = keywords;\n                    data.pltCode = pltCode;\n                    data.phone = procGetPhoneNumbers(subbody).join(',');\n                    var group_link = procGetLinks(subbody);\n                    if (group_link && group_link.length > 0) {\n                        data.group_link = group_link.join('       ');\n                        datas.push(data);\n                        spider.postData(JSON.stringify(data));\n                    }\n                }\n                else if (jsaction.querySelector(\"div.fzUZNc\")) {\n                    console.log(\"*v********************\" + i + \"*************************************\");\n                    var title = jsaction.querySelector(\"h3\").textContent;\n                    var url = jsaction.querySelector(\"a[href]\").getAttribute(\"href\");\n                    var subbody = jsaction.querySelector(\"div.fzUZNc\").textContent;\n                    var data = {};\n                    data.title = title;\n                    data.url = url;\n                    data.body = subbody;\n                    data.googSite = googSite;\n                    data.keywords = keywords;\n                    data.pltCode = pltCode;\n                    var phone = procGetPhoneNumbers(subbody, areaCode);\n                    if (phone && phone.length > 0) {\n                        data.phone = phone.join(',  ');\n                        datas.push(data);\n                        spider.postData(JSON.stringify(data));\n                    }\n                }\n                jsaction.remove();\n            }\n        }\n        if (document.querySelector(\"div[id='botstuff'] div[data-dt='1'] a[role='button'][aria-label][data-ve-view]\")) {\n            document.querySelector(\"div[id='botstuff'] div[data-dt='1'] a[role='button'][aria-label][data-ve-view]\").click();\n        }\n\n        if (document.querySelector(\"a[aria-label='More results']\")) {\n            document.querySelector(\"a[aria-label='More results']\").click();\n        }\n\n        if (document.querySelector(\"a[id='pnnext']\")) {\n            spider.asyncRunJs(getRandomNumber(5, 9), \"checkGooglePageData\");\n            document.querySelector(\"a[id='pnnext']\").click();\n        }\n\n        if (document.querySelector(\"div[data-graft-type='insert'][data-async-rclass='search'] div[data-state-token] div[class='card-section'] a\")\n            || (document.querySelector('p[aria-level]')?.innerText?.includes(\"not match any documents\"))\n            || (document.querySelector(\"#ofr > i > a\") && document.querySelector(\"#ofr > i > a\").innerText === 'repeat the search with the omitted results included')) {\n            console.log(\"结束xx\");\n            spider.wait(3);\n            spider.endTask();\n        }\n    } catch (e) { console.log(\"出现异常：\"); console.log(e) }\n    procFBItems();\n    spider.wait(3);\n    checkGooglePageData();\n\n}\n\nfunction getRandomNumber(min, max) {\n    return Math.floor(Math.random() * (max - min + 1)) + min;\n}\n\n\nfunction checkGooglePageData() {\n    window.toScrollButtom();\n\n\n    try {\n        spider.toCheckDom(ITEMS, 100, function (flg) {\n            if (flg) {\n                procBody();\n            } else {\n                spider.endTask();\n            }\n        });\n    } catch (e) { console.log(\"出现异常：\"); console.log(e) }\n\n}\n"}