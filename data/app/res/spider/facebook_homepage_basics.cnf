{"code":"facebook_homepage_basics","moduleCode":"facebook","spiderParams":[{"dpIndex":"1","code":"keywords","requiredSign":"1","name":"关键词","type":"keyWords"},{"dpIndex":"2","code":"city","requiredSign":"2","name":"请输入城市","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");","step":"1"},{"js":"var city = spider.getSpiderParams(\"city\");\nif (city && city != 'city') StartFlag = true;\nwindow.location.href = 'https://www.facebook.com/search/pages/?q=' + keywords","step":"2"},{"js":"var city = spider.getSpiderParams(\"city\");\nconsole.log('city', city);\nvar LocalButton = 'input[aria-label=\"Location\"],input[aria-label=\"位置\"]'\nspider.toCheckDom(LocalButton, 60, function (flg) {\n    if(flg){\n        if (city && city != 'city') {\n            var ele = document.querySelector(LocalButton);\n            ele.focus();\n            ele.click();\n            document.execCommand(\"insertText\", false, city);\n        }\n    } else {\n        spider.endTask();\n    }\n});","step":"3"},{"js":"if (city && city != 'city') {\n    var dom = document.querySelector('ul[role=\"listbox\"]>li>div>div');\n    if (dom) {\n        dom.click();\n    }\n}\nStartFlag = true;","step":"4"},{"js":"checkListData(0, 1);","step":"5"}],"homeUrl":"https://www.facebook.com/","hookurls":[{"path":"https://www.facebook.com/api/graphql/","contains":"serpResponse","callbackType":"jsfunc"},{"path":"https://web.facebook.com/api/graphql/","contains":"serpResponse","callbackType":"jsfunc"}],"spiderMode":2,"name":"FB主页基础采集","sipderJson":"\nif(StartFlag){\n    var obj = JSON.parse(inJsonStr);\n    if (obj && obj.data && obj.data.serpResponse\n        && obj.data.serpResponse.results && obj.data.serpResponse.results.edges) {\n        var edges = obj.data.serpResponse.results.edges;\n        console.log('edges', edges);\n        if (edges) {\n            if (edges && edges.length > 0) {\n    \n                edges.forEach(async (o) => {\n                    var data = {};\n                    var node = o.rendering_strategy.view_model;\n                    data.keywords = spider.getSpiderParams(\"keywords\");\n                    data.city = spider.getSpiderParams(\"city\");\n    \n                    if (node.profile) {\n                        data.fbID = node.profile.id;\n    \n                        data.links = node.profile.url;\n                        data.nickname = node.profile.name;\n                    }\n                    if (node.loggedProfile) {\n    \n                        if (node.loggedProfile.typeaheadProfilePicture && node.loggedProfile.typeaheadProfilePicture.uri) {\n                            var avatarBase = await getBase64FromUrl(node.loggedProfile.typeaheadProfilePicture.uri);\n                            data.avatarBase = spider.base64TOss(avatarBase);\n                        }\n                    }\n                    if (node.primary_snippet_text_with_entities\n                        && node.primary_snippet_text_with_entities.text) {\n                        data.entities = node.primary_snippet_text_with_entities.text;\n                    }\n    \n                    spider.postData(JSON.stringify(data));\n    \n                });\n            }\n    \n        }\n    }\n}","id":34,"fields":[{"dpIndex":"1","code":"keywords","name":"关键词","type":"text"},{"dpIndex":"3","code":"nickname","name":"主页名称","type":"text"},{"dpIndex":"2","code":"fbID","name":"发布者ID","type":"text"},{"dpIndex":"5","code":"avatarBase","name":"图片","type":"image_url"},{"dpIndex":"6","code":"entities","name":"类别","type":"text"},{"dpIndex":"7","code":"links","name":"主页链接","type":"text"},{"dpIndex":"8","code":"date","name":"采集时间","type":"text"},{"dpIndex":"9","code":"city","name":"城市","type":"text"}],"spiderAppId":5,"spiderAppCode":"facebook_homepage_basics","displayIndex":0,"injectionjs":"function checkListData(nums, count) {\n    window.scrollTo({\n        top: document.body.scrollHeight,\n        behavior: 'smooth'\n    });\n    var proFile = document.querySelectorAll('div[role=\"main\"] div[role=\"feed\"]>div');\n    if (proFile == null || proFile.lenght == 0) {\n        console.log(\"没有数据啦\");\n        spider.endTask();\n    } else {\n        if (proFile.length != nums || (nums >= proFile.length && count != 5)) {\n            if (nums >= proFile.length) {\n                count++;\n            }\n            var s = 'div[role=\"main\"] div[role=\"feed\"]>div';\n            spider.toCheckDomDataWait(s, 60, function (flg) {\n                if (flg) {\n                    spider.toRunJsWaitTime(function () {\n                        console.log('proFile.length', proFile.length);\n                        checkListData(proFile.length, count);\n                    }, 5, 10);\n                } else {\n                    console.log(\"没有数据啦\");\n                    spider.endTask();\n\n                }\n            });\n        } else {\n            console.log(\"没有数据啦\");\n            spider.endTask();\n        }\n\n    }\n}\nvar StartFlag = false;\n"}