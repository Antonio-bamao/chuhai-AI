{"code":"tiktok_active_peers","moduleCode":"tiktok","spiderParams":[{"dpIndex":"1","code":"keywords","name":"请输入视频链接","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\n","step":1},{"js":"window.location.href =  keywords;","step":"2"},{"js":"spider.toCheckDom('#main-content-video_detail>div>div+div>div+div button', 15, function (flg) {\n    if (flg) {\n        document.querySelector('#main-content-video_detail>div>div+div>div+div button').click();\n        spider.toRunJsWaitTime(function () {\n            checkListData(0, 1, 1);\n        }, 3, 6);\n        \n    } else {\n        checkListData(0, 1, 0);\n    }\n});","step":"3"}],"homeUrl":"https://www.tiktok.com","hookurls":[{"path":"https://www.tiktok.com/api/comment/list/","contains":"comments","callbackName":"jsfunction","callbackType":"jsfunc"}],"spiderMode":2,"name":"Tiktokd视频评论","sipderJson":"\n\nvar obj = JSON.parse(inJsonStr);\nflag = !flag;\nif (flag && obj && obj.comments) {\n    \n    var userList = obj.comments;\n\n    userList.forEach(async (o) => {\n        var data = {};\n        data.keywords = spider.getSpiderParams(\"keywords\");\n        if (o.user.uid) {\n            data.uid = o.user.uid;\n        }\n        if (o.user.unique_id) {\n            // console.log('unique_id', o.user.unique_id);\n            data.username = o.user.unique_id;\n        }\n        if (o.user.nickname) {\n            data.nickname = o.user.nickname;\n        }\n        if (o.user.avatar_thumb && o.user.avatar_thumb.url_list && o.user.avatar_thumb.url_list.length > 0) {\n            var avatarBase = await getBase64FromUrl(o.user.avatar_thumb.url_list[0]);\n            data.cover = spider.base64TOss(avatarBase);\n        }\n        if (o.text) {\n            data.comment = o.text;\n        }\n        if (o.create_time) {\n            var createTimes = o.create_time * 1000;\n            var date = new Date(createTimes);\n            var year = date.getUTCFullYear();\n            var month = ('0' + (date.getUTCMonth() + 1)).slice(-2); // 月份是从0开始的\n            var day = ('0' + date.getUTCDate()).slice(-2);\n            var hours = ('0' + date.getUTCHours()).slice(-2);\n            var minutes = ('0' + date.getUTCMinutes()).slice(-2);\n            var seconds = ('0' + date.getUTCSeconds()).slice(-2);\n            data.createTime = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;\n        }\n\n        spider.postData(JSON.stringify(data));\n\n    });\n}\n","id":30,"fields":[{"dpIndex":"1","code":"keywords","name":"视频链接","type":"text"},{"dpIndex":"2","code":"uid","name":"用户ID","type":"text"},{"dpIndex":"3","code":"username","name":"用户名称","type":"text"},{"dpIndex":"4","code":"cover","name":"头像","type":"image_url"},{"dpIndex":"5","code":"nickname","name":"昵称","type":"text"},{"dpIndex":"6","code":"comment","name":"评论内容","type":"text"},{"dpIndex":"7","code":"createTime","name":"评论时间","type":"text"},{"dpIndex":"8","code":"date","name":"采集时间","type":"text"}],"spiderAppId":3,"spiderAppCode":"tiktok_active_peers","displayIndex":0,"injectionjs":"function smoothScrollTo(element, targetScrollTop, duration = 3000) {\n    const isWindow = element === window;\n    const startScrollTop = isWindow\n        ? window.pageYOffset\n        : element.scrollTop;\n\n    // 第一步：用1秒时间平稳上划\n    const immediateTarget = startScrollTop - 1200;\n    const firstDistance = immediateTarget - startScrollTop;\n    let firstStartTime = null;\n\n    function firstAnimation(currentTime) {\n        if (!firstStartTime) firstStartTime = currentTime;\n        const timeElapsed = currentTime - firstStartTime;\n        const progress = Math.min(timeElapsed / 800, 1);\n\n        // 计算当前滚动位置\n        const currentScrollTop = startScrollTop + firstDistance * progress;\n\n        // 应用滚动\n        if (isWindow) {\n            window.scrollTo(0, currentScrollTop);\n        } else {\n            element.scrollTop = currentScrollTop;\n        }\n\n        // 如果第一阶段动画完成，开始第二阶段\n        if (timeElapsed < 800) {\n            requestAnimationFrame(firstAnimation);\n        } else {\n            // 第二阶段：从新的位置开始平滑滚动到目标位置\n            const finalDistance = targetScrollTop - immediateTarget;\n            let finalStartTime = null;\n\n            function finalAnimation(currentTime) {\n                if (!finalStartTime) finalStartTime = currentTime;\n                const timeElapsed = currentTime - finalStartTime;\n                const progress = Math.min(timeElapsed / (duration - 1000), 1);\n\n                const currentScrollTop = immediateTarget + finalDistance * progress;\n\n                if (isWindow) {\n                    window.scrollTo(0, currentScrollTop);\n                } else {\n                    element.scrollTop = currentScrollTop;\n                }\n\n                if (timeElapsed < (duration - 1000)) {\n                    requestAnimationFrame(finalAnimation);\n                }\n            }\n\n            requestAnimationFrame(finalAnimation);\n        }\n    }\n\n    requestAnimationFrame(firstAnimation);\n}\n\nfunction checkListData(nums, count, flag) {\n    var s = 'div#main-content-video_detail div>a>span>img[loading=\"lazy\"]';\n    if (flag == 1) {\n        var elem = document.querySelector('.TUXTabBar-content>div>div')\n        if (elem) {\n            smoothScrollTo(elem, elem.scrollHeight, 3000);\n        }\n    } else {\n        smoothScrollTo(window, document.body.scrollHeight, 3000);\n        s = 'div#main-content-video_detail div>a>span>img[loading=\"lazy\"]';\n    }\n    \n    var proFile = document.querySelectorAll(s);\n    if (proFile == null || proFile.lenght == 0) {\n        console.log(\"没有数据啦1\");\n        spider.endTask();\n    } else {\n        if (proFile.length != nums || (nums >= proFile.length && count != 4)) {\n            if (nums >= proFile.length) {\n                count++;\n                console.log(\"length \",proFile.length - 1)\n                const lastElement = proFile[proFile.length - 1];\n                lastElement.scrollIntoView({behavior: 'smooth'});\n            } else {\n                count = 1;\n            }\n           \n            spider.toCheckDomDataWait(s, 60, function (flg) {\n                if (flg) {\n                    spider.toRunJsWaitTime(function () {\n                        console.log('proFile.length', proFile.length);\n                        checkListData(proFile.length, count, flag);\n                    }, 8, 11);\n                } else {\n                    console.log(\"没有数据啦2\");\n                    spider.endTask();\n\n                }\n            });\n        } else {\n            console.log(\"没有数据啦3\");\n            spider.endTask();\n        }\n    }\n}\n\nvar flag = false;\n"}