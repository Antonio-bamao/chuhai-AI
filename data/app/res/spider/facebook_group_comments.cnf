{"code":"facebook_group_comments","moduleCode":"facebook","spiderParams":[{"dpIndex":"1","code":"keywords","name":"请输入小组链接","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");","step":"1"},{"js":"window.location.href=  keywords","step":"2"},{"js":"checkListData(0,1);","step":"3"}],"homeUrl":"https://www.facebook.com/","hookurls":[{"path":"https://www.facebook.com/api/graphql/","contains":"interesting_top_level_comments","callbackType":"jsfunc"},{"path":"https://web.facebook.com/api/graphql/","contains":"interesting_top_level_comments","callbackType":"jsfunc"}],"spiderMode":0,"name":"FB小组评论截流","sipderJson":"var strs = inJsonStr.split('\\n');\nstrs.forEach(str => {\n    var json = JSON.parse(str);\n    try {\n        if (json?.data?.node?.group_feed?.edges) {\n            var edges = json.data.node.group_feed.edges;\n            edges.forEach(async (o) => {\n                if (o?.node?.comet_sections?.feedback?.story?.comet_feed_ufi_container?.story?.feedback_context?.interesting_top_level_comments) {\n                    var comments = o.node.comet_sections.feedback.story.comet_feed_ufi_container.story.feedback_context.interesting_top_level_comments;\n                    postComments(comments);\n                    console.log('1')\n                }\n                else if (o?.node?.comet_sections?.feedback?.story?.comet_feed_ufi_container?.story?.story_ufi_container?.story?.feedback_context?.interesting_top_level_comments) {\n                    var comments = o.node.comet_sections.feedback.story.comet_feed_ufi_container.story.story_ufi_container.story.feedback_context.interesting_top_level_comments;\n                    postComments(comments);\n                    console.log('2')\n                }\n                else if(o?.node?.comet_sections?.feedback?.story?.story_ufi_container?.story?.feedback_context?.interesting_top_level_comments){\n                    var comments = o.node.comet_sections.feedback.story.story_ufi_container.story.feedback_context.interesting_top_level_comments;\n                    postComments(comments);\n                        console.log('3')\n                }\n\n            });\n        }\n        else if (json?.data?.node?.comet_sections?.feedback?.story?.comet_feed_ufi_container?.story?.story_ufi_container?.story?.feedback_context?.interesting_top_level_comments) {\n            var comments = json.data.node.comet_sections.feedback.story.comet_feed_ufi_container.story.story_ufi_container.story.feedback_context.interesting_top_level_comments\n            postComments(comments)\n            console.log('4')\n        }\n        else if (json?.data?.node?.comet_sections?.feedback?.story?.comet_feed_ufi_container?.story?.feedback_context?.interesting_top_level_comments) {\n            var comments = json.data.node.comet_sections.feedback.story.comet_feed_ufi_container.story.feedback_context.interesting_top_level_comments;\n            postComments(comments)\n            console.log('5')\n        }\n        else if (json?.data?.node?.comet_sections?.feedback?.story?.story_ufi_container?.story?.feedback_context?.interesting_top_level_comments) {\n            var comments = json.data.node.comet_sections.feedback.story.story_ufi_container.story.feedback_context.interesting_top_level_comments;\n            console.log('6')\n            postComments(comments)\n        }\n    } catch (error) {\n        console.log(error);\n    }\n\n})","id":38,"fields":[{"dpIndex":"1","code":"keywords","name":"小组链接","type":"text"},{"dpIndex":"3","code":"username","name":"发布者","type":"text"},{"dpIndex":"2","code":"fbID","name":"发布者ID","type":"text"},{"dpIndex":"6","code":"content","name":"发布内容","type":"text"},{"dpIndex":"7","code":"links","name":"链接","type":"text"},{"dpIndex":"8","code":"date","name":"采集时间","type":"text"}],"spiderAppCode":"0","displayIndex":0,"injectionjs":"function checkListData(nums, count) {\n    window.scrollTo({\n        top: document.body.scrollHeight,\n        behavior: 'smooth'\n    });\n    var links = window.location.href;\n    var proFile = null;\n    var groupsFlag = false;\n    if (links.indexOf('groups') != -1) {\n        proFile = document.querySelectorAll('div[role=\"feed\"]>div');\n        groupsFlag = true;\n    } else {\n        groupsFlag = false;\n        proFile = document.querySelectorAll('div[data-pagelet=\"ProfileTimeline\"]>div');\n    }\n    if (proFile == null || proFile.lenght == 0) {\n        console.log(\"没有数据啦1\");\n        spider.endTask();\n    } else {\n        if (proFile.length != nums || (nums >= proFile.length && count != 5)) {\n            if (nums >= proFile.length) {\n                count++;\n            }\n            var s = '';\n            if (groupsFlag) {\n                s = 'div[role=\"feed\"]>div';\n            } else {\n                s = 'div[data-pagelet=\"ProfileTimeline\"]>div';\n            }\n\n            spider.toCheckDomDataWait(s, 60, function (flg) {\n                if (flg) {\n                    spider.toRunJsWaitTime(function () {\n                        console.log('proFile.length', proFile.length);\n                        checkListData(proFile.length, count);\n                    }, 2, 8);\n                } else {\n                    console.log(\"没有数据啦2\");\n                    spider.endTask();\n\n                }\n            });\n        }\n        else {\n            console.log(\"没有数据啦3\");\n            spider.endTask();\n        }\n    }\n}\n\n\nfunction postComments(comments) {\n    comments.forEach(async (o) => {\n        var data = {};\n        data.keywords = spider.getSpiderParams(\"keywords\");\n        if (o.comment.body && o.comment.body.text) {\n            data.content = o.comment.body.text;\n        }\n        if (o.comment.author) {\n            data.username = o.comment.author.name;\n            data.fbID = o.comment.author.id;\n            data.gender = o.comment.author.gender;\n            data.links = o.comment.author.url;\n        }\n        spider.postData(JSON.stringify(data));\n    });\n}\n"}