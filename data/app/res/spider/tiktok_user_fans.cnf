{"code":"tiktok_user_fans","moduleCode":"tiktok","spiderParams":[{"dpIndex":"1","code":"keywords","requiredSign":"1","name":"请输入同行链接或用户名","type":"keyWords"}],"steps":[{"js":"var linkurl = spider.getSpiderParams(\"keywords\");\nspider.wait(3);\nconsole.log(linkurl);\nif(linkurl.startsWith(\"http\")){\n     spider.doHref(linkurl);\n}else{\n    spider.doHref(\"https://www.tiktok.com/@\"+linkurl );\n}","step":1},{"js":"spider.toCheckDom(\"span[data-e2e='followers'][class*='SpanUnit']\", 60,function(flg){\n    if(flg){\n        console.log(\"等待页面加载\");\n        document.querySelector(\"span[data-e2e='followers'][class*='SpanUnit']\").click();\n    }else{\n        console.log(\"网页卡顿\");\n    }\n});","step":2},{"js":"\tspider.toCheckDom(\"div[role='dialog'][data-e2e='follow-info-popup'] div[class*='DivUserListContainer']\",60,function(flg){\n\t\tif(flg){\n\t\t\tconsole.log(\"检测粉丝框,准备滑动\");\n\t\t\tcheckListData();\n\t\t}else{\n\t\t console.log(\"没有检测粉丝框\") ;spider.endTask(); \n\t\t}\n\t});","step":"3"}],"homeUrl":"https://www.tiktok.com","hookurls":[{"path":"tiktok.com/api/user/list","contains":"userList","callbackName":"jsfunction","callbackType":"jsfunc"},{"path":"scripts","contains":"userList","callbackType":"jsfunc"}],"spiderMode":2,"name":"Tiktok同行粉丝","sipderJson":"var obj = JSON.parse(inJsonStr);\nif (obj && obj.userList) {\n    var userList = obj.userList;\n    console.log(userList);\n    userList.forEach(async (o) => {\n        var nickname = o.user.nickname;\n        var tkid = o.user.id;\n        var uuid = o.user.uniqueId;\n        var avatarLarger = o.user.avatarLarger;\n\n        if (null != avatarLarger && avatarLarger != \"\") {\n            var avatarBase = await getBase64FromUrl(avatarLarger);\n            avatarLarger = spider.base64TOss(avatarBase);\n        }\n        var signature = o.user.signature;\n        var diggCount = o.stats.diggCount;\n        var followerCount = o.stats.followerCount;\n        var followingCount = o.stats.followingCount;\n        var friendCount = o.stats.friendCount;\n        var heart = o.stats.heart;\n        var heartCount = o.stats.heartCount;\n        var videoCount = o.stats.videoCount;\n        var data = {};\n        data.tkid = tkid;\n        data.uuid = uuid;\n        data.keyword = spider.getSpiderParams(\"keywords\");\n        data.nickname = nickname;\n        data.avatarLarger = avatarLarger;\n        data.signature = signature;\n        data.diggCount = diggCount;\n        data.followerCount = followerCount;\n        data.followingCount = followingCount;\n        data.friendCount = friendCount;\n        data.heart = heart;\n        data.heartCount = heartCount;\n        data.videoCount = videoCount;\n        spider.postData(JSON.stringify(data));\n\n    });\n}\n","id":1,"fields":[{"dpIndex":"1","code":"tkid","name":"用户ID","type":"text"},{"dpIndex":"2","code":"uuid","name":"用户名","type":"text"},{"dpIndex":"3","code":"nickname","name":"昵称","type":"text"},{"dpIndex":"4","code":"avatarLarger","name":"头像","type":"image_url"},{"dpIndex":"6","code":"followerCount","name":"粉丝","type":"int"},{"dpIndex":"7","code":"followingCount","name":"关注","type":"int"},{"dpIndex":"9","code":"videoCount","name":"视频数","type":"int"},{"dpIndex":"11","code":"date","name":"采集时间","type":"text"},{"dpIndex":"0","code":"keyword","name":"同行链接/帐号","type":"text"}],"spiderAppId":3,"spiderAppCode":"tiktok_user_fans","displayIndex":0,"injectionjs":"function checkListData() {\n    var userListContainer = document.querySelector(\"div[role='dialog'][data-e2e='follow-info-popup'] div[class*='DivUserListContainer']\");\n    if (userListContainer) {\n        userListContainer.scrollTo(0, userListContainer.scrollHeight);\n    }\n    var userLis = document.querySelectorAll(\"div[role='dialog'][data-e2e='follow-info-popup'] div[class*='DivUserListContainer'] li\");\n\n    if (userLis) {\n        userLis.forEach(function (a) { a.remove(); });\n    }\n\n    var s = \"div[role='dialog'][data-e2e='follow-info-popup'] div[class*='DivUserListContainer'] li\";\n    spider.toCheckDomDataWait(s, 30, function (flg) {\n        if (flg) {\n            spider.toRunJsWaitTime(function () {\n                checkListData();\n            }, 1, 4);\n        } else {\n            console.log(\"没有数据啦\"); spider.endTask();\n\n        }\n    });\n}\n"}