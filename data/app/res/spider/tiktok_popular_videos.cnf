{"code":"tiktok_popular_videos","moduleCode":"tiktok","spiderParams":[{"dpIndex":"1","code":"keywords","name":"请输入关键词","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\n// window.location.href = 'https://www.tiktok.com/search/video?q=' + keywords;\nspider.wait(3);\nspider.doHref('https://www.tiktok.com/search/video?q=' + keywords);","step":1},{"js":"spider.toClick('div[data-e2e=\"search-tab-list\"]>div>div>div:nth-child(3)',60);","step":"2"},{"js":"autoScroll();\n//spider.endTask();","step":"3"}],"homeUrl":"https://www.tiktok.com","hookurls":[{"path":"https://www.tiktok.com/api/search/item/full/","contains":"item_list","callbackName":"jsfunction","callbackType":"jsfunc"}],"spiderMode":2,"name":"Tiktok热门视频采集","sipderJson":"\nvar obj = JSON.parse(inJsonStr);\n\nif (obj && obj.item_list) {\n    var userList = obj.item_list;\n  \n    userList.forEach(async(o) => {\n        var data = {};\n        data.keywords = spider.getSpiderParams(\"keywords\");\n        if (o.desc) {\n            data.title = o.desc;\n        }\n        var videoUrl = \"https://www.tiktok.com/\";\n        if (o.author.uniqueId) {\n            videoUrl = videoUrl + \"@\" + o.author.uniqueId;\n        }\n        videoUrl = videoUrl + '/video/'+ o.id;\n        data.videoUrl = videoUrl;\n        if (o.video.cover) {\n            var avatarBase = await getBase64FromUrl(o.video.cover);\n            data.cover = spider.base64TOss(avatarBase);\n\n        }\n        if (o.video.downloadAddr) {\n            data.downloadAddr = o.video.downloadAddr\n        }\n        if (o.video.duration) {\n            data.duration = o.video.duration\n        }\n        var challenges = \"\";\n        if (o.challenges && o.challenges.length > 0) {\n            for (var i = 0; i < o.challenges.length; i++) {\n                challenges = challenges + o.challenges[i].title + \" \";\n            }\n        }\n        data.challenges = challenges;\n        if (o.stats) {\n            data.diggCount = o.stats.diggCount;\n            data.shareCount = o.stats.shareCount;\n            data.commentCount = o.stats.commentCount;\n            data.playCount = o.stats.playCount;\n        }\n        if (o.author.nickname) {\n            data.nickname = o.author.nickname;\n        }\n\t\tif (o.author.uniqueId) {\n            data.uniqueId = o.author.uniqueId;\n        }\n        if (o.author.avatarThumb) {\n        //    var avatarBase2 = await getBase64FromUrl(o.author.avatarThumb);\n        //    data.avatarThumb = spider.base64TOss(avatarBase2);\n        }\n        if (o.authorStats) {\n            data.followingCount = o.authorStats.followingCount;\n            data.followerCount = o.authorStats.followerCount;\n            data.heartCount = o.authorStats.heartCount;\n            data.videoCount = o.authorStats.videoCount;\n            data.videoCount = o.authorStats.videoCount;\n            data.authorDiggCount = o.authorStats.diggCount;\n        }\n        if (o.createTime) {\n            var date = new Date(o.createTime * 1000);\n            var year = date.getUTCFullYear();\n            var month = ('0' + (date.getUTCMonth() + 1)).slice(-2); // 月份是从0开始的\n            var day = ('0' + date.getUTCDate()).slice(-2);\n            var hours = ('0' + date.getUTCHours()).slice(-2);\n            var minutes = ('0' + date.getUTCMinutes()).slice(-2);\n            var seconds = ('0' + date.getUTCSeconds()).slice(-2);\n            data.createTime = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;\n        }\n        spider.postData(JSON.stringify(data));\n\n    });\n}\n","id":28,"fields":[{"dpIndex":"1","code":"keywords","name":"关键词","type":"text"},{"dpIndex":"2","code":"title","name":"标题","type":"text"},{"dpIndex":"3","code":"videoUrl","name":"播放链接","type":"text"},{"dpIndex":"4","code":"cover","name":"缩略图","type":"image_url"},{"dpIndex":"6","code":"downloadAddr","name":"下载地址","type":"text"},{"dpIndex":"7","code":"duration","name":"时长","type":"int"},{"dpIndex":"8","code":"challenges","name":"挑战","type":"int"},{"dpIndex":"22","code":"date","name":"采集时间","type":"text"},{"dpIndex":"9","code":"diggCount","name":"点赞数","type":"int"},{"dpIndex":"10","code":"shareCount","name":"分享数","type":"int"},{"dpIndex":"11","code":"commentCount","name":"评论数","type":"int"},{"dpIndex":"12","code":"playCount","name":"播放量","type":"int"},{"dpIndex":"13","code":"nickname","name":"昵称","type":"text"},{"dpIndex":"15","code":"avatarThumb","name":"头像","type":"image_url"},{"dpIndex":"16","code":"followingCount","name":"关注","type":"int"},{"dpIndex":"17","code":"followerCount","name":"粉丝","type":"int"},{"dpIndex":"18","code":"heartCount","name":"红心","type":"int"},{"dpIndex":"19","code":"videoCount","name":"视频","type":"int"},{"dpIndex":"20","code":"authorDiggCount","name":"获赞","type":"int"},{"dpIndex":"21","code":"createTime","name":"发布时间","type":"text"},{"dpIndex":"14","code":"uniqueId","name":"作者","type":"text"}],"spiderAppId":3,"spiderAppCode":"tiktok_popular_videos","displayIndex":0,"injectionjs":"function autoScroll() {\n    let videoPageList = document.querySelectorAll('div[data-e2e=\"search_video-item\"]');\n    let lastVideo = videoPageList[videoPageList.length - 1];\n    if (!lastVideo) return;\n    // 记录滚动前的数量\n    let prevCount = videoPageList.length;\n    // 执行滚动\n    lastVideo.scrollIntoView({ behavior: 'smooth' });\n    // 等待1秒后检查结果\n    setTimeout(() => {\n        let newVideoPageList = document.querySelectorAll('div[data-e2e=\"search_video-item\"]');\n        \n        // 如果数量增加了，说明加载成功，继续滚\n        if (newVideoPageList.length > prevCount) {\n            console.log(`加载成功：${newVideoPageList.length} 个视频`);\n            autoScroll(); // 递归调用，继续下一轮\n        } else {\n            // 如果数量没变，可能网慢或到底了，再给它一次机会（多等1秒）\n            // 如果还是没变，就停止\n            setTimeout(() => {\n                let finalList = document.querySelectorAll('div[data-e2e=\"search_video-item\"]');\n                if (finalList.length > prevCount) {\n                    autoScroll();\n                } else {\n                    console.log('页面已到底部或加载停滞');\n                }\n            }, 1000);\n        }\n    }, 1000); // 每次滚动的基准间隔\n}"}