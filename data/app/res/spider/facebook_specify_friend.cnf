{"code":"facebook_specify_friend","moduleCode":"facebook","spiderParams":[{"dpIndex":"1","code":"keywords","requiredSign":"1","name":"关键词","type":"keyWords"},{"dpIndex":"2","code":"city","requiredSign":"2","name":"请输入地址","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");","step":"1"},{"js":"window.location.href ='https://www.facebook.com/search/top/?q=' + keywords;","step":"2"},{"js":"spider.toCheckDomDataWait('div[role=\"list\"] > div[role=\"listitem\"] a[href^=\"/search/people\"]', 60, function (flg) {\n    if (flg) {\n        document.querySelector('div[role=\"list\"] > div[role=\"listitem\"] a[href^=\"/search/people\"]').click()\n    } else {\n        console.log(\"没有数据啦\");\n        spider.endTask();\n    }\n});","step":"3"},{"js":"var city = spider.getSpiderParams(\"city\");\nconsole.log('city', city);\nif (city && city != 'city') {\n    var ele = document.querySelector('div[role=\"list\"] > div[role=\"listitem\"] input[aria-label=\"城市\"]');\n    if (ele) {\n        ele.focus();\n        ele.click();\n        document.execCommand(\"insertText\", false, city);\n    }\n\n}","step":"4"},{"js":"if (city && city != 'city'){\nvar dom = document.querySelector('ul[role=\"listbox\"]>li>div>div');\nif (dom){\ndom.click();\n}\n}","step":"5"},{"js":"console.log('开始采集数据');\ncheckListData(0,1);","step":"6"}],"homeUrl":"https://www.facebook.com/","hookurls":[{"path":"https://www.facebook.com/api/graphql/","contains":"rendering_strategy","callbackType":"jsfunc"},{"path":"https://web.facebook.com/api/graphql/","contains":"rendering_strategy","callbackType":"jsfunc"}],"spiderMode":2,"name":"FB指定好友采集","sipderJson":"var obj = JSON.parse(inJsonStr);\n// console.log('obj111', obj);\nif (obj && obj.data && obj.data.serpResponse && obj.data.serpResponse.results\n    && obj.data.serpResponse.results.edges) {\n    var edges = obj.data.serpResponse.results.edges;\n    // console.log('user', edges);\n\n    edges.forEach(async (o) => {\n        var data = {};\n        if (o.rendering_strategy\n            && o.rendering_strategy.view_model\n            && o.rendering_strategy.view_model.profile) {\n            data.fbId = o.rendering_strategy.view_model.profile.id;\n            data.links = o.rendering_strategy.view_model.profile.url;\n            data.username = o.rendering_strategy.view_model.profile.name;\n        }\n\n        data.keywords = spider.getSpiderParams(\"keywords\");\n        var city = spider.getSpiderParams(\"city\");\n        if (city && city != 'city') {\n            data.city = city;\n        }\n        if (o.rendering_strategy &&\n            o.rendering_strategy.view_model &&\n            o.rendering_strategy.view_model.profile &&\n            o.rendering_strategy.view_model.profile.profile_picture &&\n            o.rendering_strategy.view_model.profile.profile_picture.uri) {\n            var avatarLarger = o.rendering_strategy.view_model.profile.profile_picture.uri\n            if (null != avatarLarger && avatarLarger != \"\") {\n                try {\n                    var avatarBase = await getBase64FromUrl(avatarLarger);\n                }\n                catch (e) {\n                    console.log('getBase64FromUrl()不存在', e);\n                }\n                avatarLarger = spider.base64TOss(avatarBase);\n            }\n            data.avatarLarger = avatarLarger;\n        }\n        if (data.username)\n            spider.postData(JSON.stringify(data));\n    });\n}\n","id":19,"fields":[{"dpIndex":"1","code":"keywords","name":"关键词","type":"text"},{"dpIndex":"2","code":"username","name":"用户名","type":"text"},{"dpIndex":"3","code":"avatarLarger","name":"头像","type":"image_url"},{"dpIndex":"4","code":"fbId","name":"FB账户","type":"text"},{"dpIndex":"5","code":"links","name":"链接","type":"text"},{"dpIndex":"6","code":"date","name":"采集时间","type":"text"},{"dpIndex":"7","code":"city","name":"城市","type":"text"}],"spiderAppId":5,"spiderAppCode":"facebook_specify_friend","displayIndex":0,"injectionjs":"function checkListData(nums, count) {\n    window.scrollTo({\n        top: document.body.scrollHeight,\n        behavior: 'smooth'\n    });\n\n    var presentsx = 'a[role=\"presentation\"]';\n    spider.toCheckDomDataWait(presentsx, 60, function (flg) {\n        if (!flg) {\n            console.log(\"没有数据啦\");\n            spider.endTask();\n        }\n    });\n\n    var userList = document.querySelectorAll(presentsx);\n\n    if (userList == null || userList.length == 0) {\n        console.log(\"没有数据啦\");\n        spider.endTask();\n    } else {\n        if (nums == userList.length && count == 5) {\n            spider.endTask();\n        } else {\n\t\t\tif (nums == userList.length){\n\t\t\t\tcount++;\n\t\t\t}\n            var s = 'a[role=\"presentation\"]';\n            spider.toCheckDomDataWait(s, 60, function (flg) {\n                if (flg) {\n                    spider.toRunJsWaitTime(function () {\n                        console.log('userList.length', userList.length);\n                        checkListData(userList.length,count);\n                    }, 5, 10);\n                } else {\n                    console.log(\"没有数据啦\");\n                    spider.endTask();\n\n                }\n            });\n        }\n\n    }\n}\n"}