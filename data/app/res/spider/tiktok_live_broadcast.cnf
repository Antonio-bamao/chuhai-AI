{"code":"tiktok_live_broadcast","moduleCode":"tiktok","spiderParams":[{"dpIndex":"1","code":"keywords","name":"请输入直播间链接","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\n\nwindow.location.href = keywords;","step":"1"},{"js":"spider.toCheckDom('div[class=\"relative w-full\"]>div>div.w-full', 80, function (flg) {\n    if (flg) {\n        creatBtn()\n        setInterval(() => {\n            getUserData()\n        }, 1200);\n        setInterval(() => {\n            closeUser()\n        }, 1000);\n        // mijava.startIntervalRunJs(2000, \"getUserData\")\n    }\n});","step":"2"}],"homeUrl":"https://www.tiktok.com","hookurls":[{"path":"https://webcast.tiktok.com/webcast/","contains":"allow_find_by_contacts","callbackType":"jsfunc"},{"path":"https://webcast.us.tiktok.com/webcast/","contains":"allow_find_by_contacts","callbackType":"jsfunc"}],"spiderMode":2,"name":"tk直播间截流","sipderJson":"var obj = JSON.parse(inJsonStr);\n\nif (obj && obj.data && obj.data.nickname) {\n    var data = {};\n    data.keywords = spider.getSpiderParams(\"keywords\");\n\n    data.id_str = obj.data.id_str;\n    data.follower_count = obj.data?.follow_info?.follower_count;\n    data.following_count = obj.data?.follow_info?.following_count;\n    data.nickname = obj.data?.nickname;\n    data.display_id = obj.data?.display_id;\n    data.like = obj.data?.author_stats?.video_total_favorite_count\n    console.log(data);\n    spider.postData(JSON.stringify(data));\n\n}","id":230,"fields":[{"dpIndex":"1","code":"keywords","name":"直播间链接","type":"text"},{"dpIndex":"2","code":"display_id","name":"用户名","type":"text"},{"dpIndex":"3","code":"nickname","name":"昵称","type":"text"},{"dpIndex":"4","code":"id_str","name":"ID","type":"text"},{"dpIndex":"5","code":"follower_count","name":"粉丝","type":"text"},{"dpIndex":"6","code":"following_count","name":"关注","type":"text"},{"dpIndex":"7","code":"like","name":"点赞","type":"text"}],"spiderAppId":3,"spiderAppCode":"tiktok_live_broadcast","displayIndex":0,"injectionjs":"var ProName = \"\";\nvar ProText = \"\";\nvar NowName = ProName;\nvar NowText = ProText;\n\n\nfunction closeUser() {\n    // var s = document.querySelector('div[class=\"tiktok-1ncf7vi e1yzsfo98\"]')\n    var s = document.querySelector('svg[width=\"1em\"][class=\"text-color-TextReverse2\"]')\n    if (s) {\n        s.parentNode.click()\n    }\n}\n\nfunction clickUser() {\n    var ele = document.querySelectorAll('div[class=\"relative w-full\"]>div>div.w-full')[document.querySelectorAll('div[class=\"relative w-full\"]>div>div.w-full').length - 2];\n    var u = ele.querySelector('div[class=\"flex flex-col justify-start items-start overflow-hidden flex-1 break-words\"]>div>div>div')\n    if (u)\n        u.click()\n}\n\nfunction clickUser1() {\n    var ele = document.querySelectorAll('div[class=\"relative w-full\"]>div>div.w-full')[document.querySelectorAll('div[class=\"relative w-full\"]>div>div.w-full').length - 2];\n    var u = ele.querySelector('div[data-e2e=\"social-message-text\"]>div')\n    if (u)\n        u.click()\n}\n\nfunction getUserData() {\n    var ele = document.querySelectorAll('div[class=\"relative w-full\"]>div>div.w-full')[document.querySelectorAll('div[class=\"relative w-full\"]>div>div.w-full').length - 2];\n    var u = ele.querySelectorAll('div[class=\"flex flex-col justify-start items-start overflow-hidden flex-1 break-words\"]>div')\n    if (u.length > 0) {\n        NowName = u[0].querySelector('div[data-e2e=\"message-owner-name\"]').innerText;\n        NowText = u[1].innerText;\n        if (ProName != NowName && ProText != NowText) {\n            ProName = NowName;\n            ProText = NowText;\n            clickUser();\n            setTimeout(() => {\n                closeUser();\n            }, 1000);\n\n        }\n    } else {\n        var isEnter = ele.querySelector('div[data-e2e=\"social-message-text\"]')\n        if (isEnter) {\n            NowName = isEnter.innerText.split('\\n')[0];\n            NowText = isEnter.innerText.split('\\n')[1];\n            if (ProName != NowName && ProText != NowText) {\n                ProName = NowName;\n                ProText = NowText;\n                clickUser1();\n                setTimeout(() => {\n                    closeUser();\n                }, 1000);\n            }\n        }\n    }\n}\n\nfunction creatBtn() {\n    var btn = document.createElement(\"button\");\n    btn.innerText = \"点击结束直播采集\";\n\n    btn.style.position = \"fixed\";\n    btn.style.top = \"20px\";\n    btn.style.right = \"20px\";\n    btn.style.padding = \"10px 20px\";\n    btn.style.borderRadius = \"8px\";\n    btn.style.background = \"#4CAF50\";\n    btn.style.color = \"white\";\n    btn.style.border = \"none\";\n    btn.style.cursor = \"pointer\";\n    btn.style.zIndex = \"999999\";   // 🔑 保证在最顶层\n\n    btn.onclick = () => { spider.endTask(); }\n\n    document.body.appendChild(btn);\n}\n"}