{"code":"facebook_group_members","moduleCode":"facebook","spiderParams":[{"dpIndex":"1","code":"keywords","requiredSign":"1","name":"请输入小组链接","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\nconsole.log(keywords);\nwindow.location.href = keywords","step":"1"},{"js":"spider.toCheckDomDataWait(\"a[role='tab'][href$='members/']\", 20, function (flg) {\n    if (flg) {\n        document.querySelector(\"a[role='tab'][href$='members/']\").click()\n    } else {\n        spider.endTask();\n    }\n});","step":"2"},{"js":"var s = 'div[role=\"list\"]>div[role=\"listitem\"]';\nspider.toCheckDomDataWait(s, 60, function (flg) {\n    if (flg) {\n        checkListData(0, 1);\n    } else {\n        spider.endTask();\n    }\n});","step":"3"}],"homeUrl":"https://www.facebook.com/","hookurls":[{"path":"https://www.facebook.com/api/graphql/","contains":"new_members","callbackType":"jsfunc"},{"path":"https://www.facebook.com/groups/","contains":"new_members","callbackType":"jsfunc"},{"path":"https://web.facebook.com/api/graphql/","contains":"new_members","callbackType":"jsfunc"},{"path":"https://web.facebook.com/groups/","contains":"new_members","callbackType":"jsfunc"}],"spiderMode":0,"name":"FB小组成员采集","sipderJson":"\nif (inJsonStr.indexOf('<html') != -1) {\n    var str = extractString(cutString(inJsonStr));\n    var obj = JSON.parse(str);\n    var edges = obj.edges;\n    edges.forEach(async (o) => {\n        var data = {};\n        if (o.node) {\n            if (o?.join_status_text?.text) {\n                data.joinTime = o.join_status_text.text;\n            }\n            var viewModel = o.node;\n            data.username = viewModel.name;\n            if (viewModel.id) {\n                data.fbID = viewModel.id;\n            }\n            if (viewModel.url) {\n                data.links = viewModel.url;\n            }\n            if (viewModel?.bio_text?.text) {\n                data.currWork = viewModel.bio_text.text;\n            }\n            data.keywords = spider.getSpiderParams(\"keywords\");\n            if (viewModel.profile_picture && viewModel.profile_picture.uri) {\n                var avatarLarger = viewModel.profile_picture.uri\n                if (null != avatarLarger && avatarLarger != \"\") {\n                    var avatarBase = await getBase64FromUrl(avatarLarger);\n                    avatarLarger = spider.base64TOss(avatarBase);\n                }\n                data.avatarLarger = avatarLarger;\n            }\n            spider.postData(JSON.stringify(data));\n        }\n\n    });\n} else {\n    var obj = JSON.parse(inJsonStr);\n    if (obj && obj.data && obj.data.node && obj.data.node.new_members\n        && obj.data.node.new_members.edges) {\n        var edges = obj.data.node.new_members.edges;\n        console.log('user', edges);\n\n        edges.forEach(async (o) => {\n            var data = {};\n            if (o.node) {\n                if (o?.join_status_text?.text) {\n                    data.joinTime = o.join_status_text.text;\n                }\n                var viewModel = o.node;\n                data.username = viewModel.name;\n                if (viewModel.id) {\n                    data.fbID = viewModel.id;\n                }\n                if (viewModel.url) {\n                    data.links = viewModel.url;\n                }\n                if (viewModel?.bio_text?.text) {\n                    data.currWork = viewModel.bio_text.text;\n                }\n                data.keywords = spider.getSpiderParams(\"keywords\");\n                if (viewModel.profile_picture && viewModel.profile_picture.uri) {\n                    var avatarLarger = viewModel.profile_picture.uri\n                    if (null != avatarLarger && avatarLarger != \"\") {\n                        var avatarBase = await getBase64FromUrl(avatarLarger);\n                        avatarLarger = spider.base64TOss(avatarBase);\n                    }\n                    data.avatarLarger = avatarLarger;\n                }\n\n                spider.postData(JSON.stringify(data));\n            }\n\n        });\n\n    }\n}\n\n","id":26,"fields":[{"dpIndex":"1","code":"keywords","name":"小组链接","type":"text"},{"dpIndex":"3","code":"username","name":"粉丝名称","type":"text"},{"dpIndex":"4","code":"avatarLarger","name":"头像","type":"image_url"},{"dpIndex":"2","code":"fbID","name":"FB账户","type":"text"},{"dpIndex":"5","code":"links","name":"FB链接","type":"text"},{"dpIndex":"6","code":"joinTime","name":"加入时间","type":"text"},{"dpIndex":"7","code":"currWork","name":"目前","type":"text"},{"dpIndex":"8","code":"date","name":"采集时间","type":"text"}],"spiderAppCode":"0","displayIndex":0,"injectionjs":"var lastNumber = 0;\nfunction checkListData(nums, count) {\n    var fbHtml = document.querySelector('html[id=\"facebook\"]')\n    fbHtml.scrollTo({\n        top: fbHtml.scrollHeight,\n        behavior: 'smooth'\n    });\n\n    var profx = 'div[role=\"list\"]>div[role=\"listitem\"]';\n\n    spider.toCheckDomDataWait(profx, 60, function (flg) {\n        if (!flg) {\n            spider.endTask();\n        }\n    });\n\n    var proFile = document.querySelectorAll(profx);\n\n    if (proFile == null || proFile.lenght == 0) {\n        console.log(\"没有数据啦1\");\n        spider.endTask();\n    } else {\n        if (nums != proFile.length || (nums >= proFile.length && count != 5)) {\n            if (nums >= proFile.length) {\n                count++;\n            } else {\n                count = 1;\n            }\n            var s = 'div[role=\"list\"]>div[role=\"listitem\"]';\n            spider.toCheckDomDataWait(s, 60, function (flg) {\n                if (flg) {\n                    spider.toRunJsWaitTime(function () {\n                        console.log('proFile.length', proFile.length);\n                        checkListData(proFile.length, count);\n                    }, 5, 10);\n                } else {\n                    console.log(\"没有数据啦2\");\n                    spider.endTask();\n\n                }\n            });\n        } else {\n            console.log(\"没有数据啦3\");\n            spider.endTask();\n        }\n\n    }\n}\n\nfunction cutString(str) {\n    const lastIndex = str.lastIndexOf('\"new_members\":');\n    if (lastIndex !== -1) {\n        return str.substring(lastIndex + '\"new_members\":'.length);\n    }\n    return '';\n}\nfunction extractString(str) {\n    const index = str.indexOf('\"page_info\"');\n    if (index !== -1) {\n        return str.slice(0, index - 1) + \"}\";\n    } else {\n        return '';\n    }\n}\n"}