{"code":"facebook_home_page","moduleCode":"facebook","spiderParams":[{"dpIndex":"1","code":"keywords","requiredSign":"1","name":"请输入公共主页链接","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\nspider.doHref(keywords);","step":"1"},{"js":"var s = 'div[role=\"main\"]>div:nth-last-child(1)>div:nth-child(2)>div>div:nth-child(2)>div:nth-last-child(1)>div';\nspider.toCheckDom(s, 20, function (flg) {\n    if (flg) {\n        window.scrollTo({\n            top: document.body.scrollHeight / 2,\n            behavior: 'smooth'\n        });\n        spider.toRunJsWaitTime(function () {\n            checkListData();\n        }, 3, 5);\n    } else {\n        spider.endTask();\n    }\n});","step":"2"}],"homeUrl":"https://www.facebook.com/","hookurls":[{"path":"https://www.facebook.com/api/graphql/","contains":"reactors","callbackType":"jsfunc"},{"path":"https://web.facebook.com/api/graphql/","contains":"reactors","callbackType":"jsfunc"}],"spiderMode":0,"name":"FB主页同行截流","sipderJson":"try {\n\t\n\tif (!inJsonStr.includes('\\n')){\n\t\tvar obj = JSON.parse(inJsonStr);\n    \n    if (obj && obj.data && obj.data.node && obj.data.node.reactors\n         && obj.data.node.reactors.edges) {\n        var edges = obj.data.node.reactors.edges;\n\n        edges.forEach(async(o) => {\n            var data = {};\n            var node = o.node;\n            data.fbID = node.id;\n            data.name = node.name;\n            data.links = node.url;\n\n            data.keywords = spider.getSpiderParams(\"keywords\");\n\n            if (node.profile_url) {\n                var avatarLarger = node.profile_url;\n                if (null != avatarLarger && avatarLarger != \"\") {\n                    var avatarBase = null;\n                    try {\n                        avatarBase = await getBase64FromUrl(avatarLarger);\n                    } catch (e) {\n                        console.log('getBase64FromUrl()不存在', e);\n                    }\n                    avatarLarger = spider.base64TOss(avatarBase);\n                }\n                data.avatarLarger = avatarLarger;\n            }\n\n            spider.postData(JSON.stringify(data));\n        });\n\n    }\n\t}\n    \n} catch (error) {\n    console.log(error);\n}\n","id":100,"fields":[{"dpIndex":"1","code":"keywords","name":"公共主页链接","type":"text"},{"dpIndex":"2","code":"avatarLarger","name":"图片","type":"image_url"},{"dpIndex":"2","code":"fbID","name":"FB账号","type":"text"},{"dpIndex":"6","code":"name","name":"粉丝名称","type":"text"},{"dpIndex":"7","code":"links","name":"链接","type":"text"},{"dpIndex":"8","code":"date","name":"采集时间","type":"text"}],"spiderAppCode":"0","displayIndex":0,"injectionjs":"function checkListData() {\n    var proFile = document.querySelectorAll('div[role=\"main\"]>div:nth-last-child(1)>div:nth-child(2)>div>div:nth-child(2)>div:nth-last-child(1)>div');\n    console.log('proFile', proFile);\n    if (proFile == null || proFile.length == 0) {\n        console.log(\"没有数据啦\");\n        spider.endTask();\n    } else {\n        var doms = proFile[0];\n        if (doms) {\n            var ignoreDynamic = doms.querySelector('div[data-visualcompletion=\"ignore-dynamic\"] span[role=\"toolbar\"]');\n            console.log('ignoreDynamic', ignoreDynamic);\n            if (ignoreDynamic) {\n                var nextElement = ignoreDynamic.nextElementSibling;\n                console.log('nextElement', nextElement);\n                if (nextElement) {\n                    nextElement.querySelector('div[role=\"button\"][tabindex=\"0\"]').click();\n                    spider.wait(2)\n                    removeDiv(1);\n                    doms.remove();\n                }\n            } else {\n                doms.remove();\n                spider.wait(2)\n                checkListData();\n            }\n\n        }\n\n    }\n}\n\nfunction removeDiv(count) {\n    var ignoreDynamic = document.querySelectorAll('div[role=\"dialog\"]>div>div>div>div+div div[data-visualcompletion=\"ignore-dynamic\"]');\n    console.log('ignoreDynamic', ignoreDynamic.length);\n    if (ignoreDynamic && ignoreDynamic.length > 1) {\n        for (var i = 0; i < ignoreDynamic.length; i++) {\n            ignoreDynamic[i].remove();\n        }\n        spider.toRunJsWaitTime(function () {\n            removeDiv(count);\n        }, 2, 4);\n\n    } else {\n        console.log('-----------', count);\n        if (count == 3) {\n            var closeDiv = document.querySelector('div[role=\"dialog\"] div[aria-hidden=\"false\"] div[role=\"button\"]');\n            if (closeDiv) {\n                closeDiv.click();\n            }\n            spider.toRunJsWaitTime(function () {\n                checkListData();\n            }, 2, 4);\n        } else {\n            spider.toRunJsWaitTime(function () {\n                count++;\n                removeDiv(count);\n            }, 2, 4);\n        }\n\n    }\n}\n"}