{"code":"tiktok_user_message_dsp","moduleCode":"tiktok","spiderParams":[{"dpIndex":"1","code":"keywords","name":"请输入用户链接","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\n\nwindow.location.href = keywords;","step":"1"},{"js":"setTimeout(() => {\n    spider.endTask();\n}, 12000)","step":"2"}],"homeUrl":"https://www.tiktok.com","hookurls":[{"path":"scripts","contains":"userInfo","callbackType":"jsfunc"}],"spiderMode":2,"name":"dsp_tk用户检测活跃","sipderJson":"if (isFirst) {\n    var html = inJsonStr;\n    var obj = null;\n    if (html.indexOf('\"webapp.user-detail\":') > -1) {\n        var str = html.substring(html.indexOf('\"webapp.user-detail\":') + '\"webapp.user-detail\":'.length);\n        var res = str.substring(0, str.indexOf('\"shareMeta\"') - 1);\n        res = res.substring(0, res.lastIndexOf(',') - 1) + \"}}}\";\n        obj = JSON.parse(res)\n    }\n    if (obj && obj.userInfo) {\n        isFirst = false;\n        var user = obj.userInfo.user\n        var stats = obj.userInfo.statsV2\n        var data = {};\n        data.keywords = spider.getSpiderParams(\"keywords\");\n        data.username = user?.nickname;\n        data.full_name = user?.uniqueId;\n        data.pk = user?.id;\n        data.biography = user?.signature;\n        data.profile_pic_url = user?.avatarThumb;\n        data.b64 = await getBase64FromUrl(data.profile_pic_url);\n        if (data.b64) {\n            var taskId = mijava.doAddFaceDetect(data.b64, function (s, m) {\n                var ndata = JSON.parse(m);\n                var _taskid = ndata.taskId;\n                if (s == 1) {\n                    //成功\t  \n                    data.gender = ndata.gender  //性别\n\n                    ndata.age     //年龄\n                } else {\n                    //失败\n                    var msg = data.msg;\n                }\n            });\n        }\n\n        data.following_count = stats?.followingCount;\n        data.follower_count = stats?.followerCount;\n        data.media_count = stats?.videoCount;\n        data.heart = stats?.heart;\n        if (data.profile_pic_url && data.username && isPush(data.follower_count > 100, data.media_count > 3, data.following_count > 20, data.heart > 100, data.biography != \"\")) {\n            data.isAtcive = \"是\";\n        } else {\n            data.isAtcive = \"否\";\n        }\n        setTimeout(() => {\n            console.log(\"Data \", data);\n            if (!data.gender) {\n                data.gender = \"无\"\n            }\n            spider.postData(JSON.stringify(data));\n        }, 5000)\n        setTimeout(() => {\n            spider.endTask();\n        }, 8000)\n\n    }\n}\n","id":244,"fields":[{"dpIndex":"1","code":"keywords","name":"用户链接","type":"text"},{"dpIndex":"3","code":"username","name":"用户名","type":"text"},{"dpIndex":"4","code":"full_name","name":"昵称","type":"text"},{"dpIndex":"5","code":"biography","name":"签名","type":"text"},{"dpIndex":"6","code":"profile_pic_url","name":"头像","type":"image_url"},{"dpIndex":"7","code":"pk","name":"ID","type":"text"},{"dpIndex":"8","code":"follower_count","name":"粉丝","type":"text"},{"dpIndex":"9","code":"following_count","name":"关注","type":"text"},{"dpIndex":"10","code":"heart","name":"点赞","type":"text"},{"dpIndex":"11","code":"media_count","name":"帖子数量","type":"text"},{"dpIndex":"13","code":"isAtcive","name":"是否活跃","type":"text"},{"dpIndex":"12","code":"gender","name":"性别","type":"text"}],"spiderAppId":3,"spiderAppCode":"tiktok_user_message_dsp","displayIndex":0,"injectionjs":"function isPush(a, b, c, d, e) {\n    const truthyCount = [a, b, c, d, e].filter(Boolean).length;\n    return truthyCount >= 2;\n}\nisFirst = true;\n"}