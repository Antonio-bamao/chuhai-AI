{"code":"tiktok_popular_account","moduleCode":"tiktok","spiderParams":[{"dpIndex":"1","code":"keywords","name":"请输入关键词","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\nwindow.location.href = 'https://www.tiktok.com/search/user?q=' + keywords;","step":1},{"js":"\tspider.toCheckDom('#main-content-search_user',60,function(flg){\n\t\tif(flg){\nspider.wait(6);\n\t\t\tcheckListData(0,1);\n\t\t}else{\n\t\t console.log(\"没有检测粉丝框\") ;spider.endTask(); \n\t\t}\n\t});","step":"2"}],"homeUrl":"https://www.tiktok.com","hookurls":[{"path":"https://www.tiktok.com/api/search/user/full/","contains":"user_list","callbackName":"jsfunction","callbackType":"jsfunc"}],"spiderMode":2,"name":"TK热门同行采集","sipderJson":"var count = countChar(inJsonStr, '{\"type\":1');\n\nvar obj = null;\nif (count == 1) {\n    obj = JSON.parse(inJsonStr);\n} else {\n    var spl = inJsonStr.split('{\"type\":1');\n    if (spl && spl.length > 0) {\n        var jsonStr = '{\"type\":1' + spl[1];\n        obj = JSON.parse(jsonStr);\n    }\n}\n\nif (obj && obj.user_list) {\n    var userList = obj.user_list;\n    if (userList.length > 50) { \n        spider.endTask();\n    }\n    userList.forEach(async (o) => {\n        var data = {};\n        data.keywords = spider.getSpiderParams(\"keywords\");\n        var user_info = o.user_info;\n        data.uniqueId = user_info.unique_id;\n        data.link = 'https://www.tiktok.com/@' + user_info.unique_id;\n        data.uid = user_info.uid;\n        data.follower = user_info.follower_count;\n        data.nickname = user_info.nickname;\n        data.signature = user_info.signature;\n        if (user_info.avatar_thumb && user_info.avatar_thumb.url_list) {\n            var avatarBase2 = await getBase64FromUrl(user_info.avatar_thumb.url_list[0]);\n            data.avatarThumb = spider.base64TOss(avatarBase2);\n        }\n        spider.postData(JSON.stringify(data));\n    });\n}\n","id":90,"fields":[{"dpIndex":"1","code":"keywords","name":"关键词","type":"text"},{"dpIndex":"2","code":"uniqueId","name":"用户名","type":"text"},{"dpIndex":"3","code":"nickname","name":"昵称","type":"text"},{"dpIndex":"9","code":"avatarThumb","name":"头像","type":"image_url"},{"dpIndex":"6","code":"uid","name":"ID","type":"text"},{"dpIndex":"7","code":"follower","name":"关注","type":"int"},{"dpIndex":"8","code":"signature","name":"签名","type":"text"},{"dpIndex":"10","code":"date","name":"采集时间","type":"text"},{"dpIndex":"4","code":"link","name":"链接","type":"text"}],"spiderAppId":3,"spiderAppCode":"tiktok_popular_account","displayIndex":0,"injectionjs":"function checkListData(previousCount = 0, noChangeCount = 0) {\n  var elements = document.querySelectorAll('.link-a11y-focus');\n  var currentCount = elements.length;\n\n  console.log('当前元素数量:', currentCount);\n\n  if (currentCount === 0) {\n      console.log(\"没有找到任何元素\");\n      spider.endTask();\n      return;\n  }\n\n  // 滚动到最后一个元素\n  var lastElement = elements[elements.length - 1];\n  lastElement.scrollIntoView({\n      behavior: 'smooth',\n      block: 'center'\n  });\n\n  if (currentCount === previousCount) {\n      noChangeCount++;\n      if (noChangeCount >= 3) {\n          console.log(\"没有更多数据了\");\n          spider.endTask();\n          return;\n      }\n  } else {\n      noChangeCount = 0;\n  }\n\n  // 使用你的框架方法等待\n  spider.toRunJsWaitTime(function() {\n      checkListData(currentCount, noChangeCount);\n  }, 2, 2);  // 等待2秒\n}\nfunction countChar(str, char) {\n  const pattern = new RegExp(char, 'g');\n  const matches = str.match(pattern);\n  return matches ? matches.length : 0;\n}"}