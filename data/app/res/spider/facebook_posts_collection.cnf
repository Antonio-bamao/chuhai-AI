{"code":"facebook_posts_collection","moduleCode":"facebook","spiderParams":[{"dpIndex":"1","code":"keywords","requiredSign":"2","name":"关键词","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\n","step":"1"},{"js":"    window.location.href ='https://www.facebook.com/search/posts/?q=bag'\n","step":"2"},{"js":"spider.toCheckDom(s, 20, function (flg) {\n    if (flg) {\n        spider.toRunJsWaitTime(function () {\n            var proFile = document.querySelectorAll(s);\n            loopClick(proFile, 0, proFile.length, 0);\n        }, 3, 5);\n    } else {\n        spider.endTask();\n    }\n});\n","step":"4"}],"homeUrl":"https://www.facebook.com/","hookurls":[{"path":"https://www.facebook.com/api/graphql/","contains":"share_url_wrapper","callbackType":"jsfunc"},{"path":"https://web.facebook.com/api/graphql/","contains":"share_url_wrapper","callbackType":"jsfunc"}],"spiderMode":0,"name":"FB指定帖子链接采集","sipderJson":"\nvar obj = JSON.parse(inJsonStr);\nvar data = {};\ndata.keywords = spider.getSpiderParams(\"keywords\");\ndata.url = obj.data.xfb_create_share_url_wrapper.share_url_wrapper.wrapped_url\nspider.postData(JSON.stringify(data));","id":226,"fields":[{"dpIndex":"1","code":"keywords","name":"关键词","type":"text"},{"dpIndex":"2","code":"url","name":"帖子链接","type":"text"}],"spiderAppCode":"0","displayIndex":0,"injectionjs":"var s = 'div[aria-label^=\"发送给好友或发布\"]';\n\nfunction loopClick(eles, l, r, count) {\n    console.log(l, r, count);\n    if (count == 5) return;\n    if (l >= r) {\n        window.scrollTo({\n            top: document.body.scrollHeight,\n            behavior: 'smooth'\n        });\n        spider.toRunJsWaitTime(function () {\n            var proFile = document.querySelectorAll(s);\n            console.log('proFile.length', proFile.length);\n            spider.toRunJsWaitTime(function () {\n                loopClick(proFile, l, proFile.length, count + 1)\n            }, 2, 3);\n        }, 5, 6);\n\n        return;\n    }\n\n    eles[l++].click()\n    spider.toCheckDomDataWait('div[aria-label=\"关闭\"]', 3, function (flg) {\n        if (flg) {\n            spider.toRunJsWaitTime(function () {\n                document.querySelector('div[aria-label=\"关闭\"]').click()\n            }, 3, 4);\n\n        }\n    });\n    spider.toRunJsWaitTime(function () {\n        var proFile = document.querySelectorAll(s);\n        loopClick(proFile, l, proFile.length, 0);\n    }, 5, 7);\n}\n"}