{"code":"facebook_designated_group","moduleCode":"facebook","spiderParams":[{"dpIndex":"1","code":"keywords","requiredSign":"1","name":"关键词","type":"keyWords"},{"dpIndex":"2","code":"city","requiredSign":"2","name":"请输入城市关键词","type":"keyWords"},{"dpIndex":"3","code":"open_group","requiredSign":"2","name":"请选择是否是公开小组","type":"yesOrNo"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\nvar openGroup= spider.getSpiderParams(\"open_group\");\n","step":"1"},{"js":"if (openGroup && openGroup =='Y'){\nwindow.location.href= 'https://www.facebook.com/search/groups/?q=' + keywords + '&filters=eyJwdWJsaWNfZ3JvdXBzOjAiOiJ7XCJuYW1lXCI6XCJwdWJsaWNfZ3JvdXBzXCIsXCJhcmdzXCI6XCJcIn0ifQ%3D%3D'\n} else {\nwindow.location.href= 'https://www.facebook.com/search/groups/?q=' + keywords\n}","step":"2"},{"js":"var city = spider.getSpiderParams(\"city\");\nconsole.log('city',city);\nif (city && city!='city'){\nvar ele = document.querySelector('input[aria-label=\"城市\"]');\nele.focus();\nele.click();\ndocument.execCommand(\"insertText\", false, city);\n}\n","step":"3"},{"js":"if (city && city !='city'){\nvar dom = document.querySelector('ul[role=\"listbox\"]>li>div>div');\nif (dom){\ndom.click();\n}\n}","step":"4"},{"js":"checkListData(0,1);","step":"5"}],"homeUrl":"https://www.facebook.com/","hookurls":[{"path":"https://www.facebook.com/api/graphql/","contains":"serpResponse","callbackType":"jsfunc"},{"path":"https://web.facebook.com/api/graphql/","contains":"serpResponse","callbackType":"jsfunc"}],"spiderMode":0,"name":"FB指定小组采集","sipderJson":"var str = inJsonStr.split('\\n')\nstr.forEach(async ij => {\n    try {\n        var obj = JSON.parse(ij);\n        if (obj && obj.data && obj.data.serpResponse && obj.data.serpResponse.results\n            && obj.data.serpResponse.results.edges) {\n            var edges = obj.data.serpResponse.results.edges;\n            // console.log('user', edges);\n\n            edges.forEach(async (o) => {\n                var data = {};\n                if (o.rendering_strategy && o.rendering_strategy.view_model) {\n                    var viewModel = o.rendering_strategy.view_model;\n                    data.username = viewModel.profile_name_with_possible_nickname;\n                    if (viewModel.profile) {\n                        data.groupId = viewModel.profile.id;\n                        data.links = viewModel.profile.url;\n                    }\n\n                    if (viewModel.primary_snippet_text_with_entities != null) {\n                        var snippetText = viewModel.primary_snippet_text_with_entities.text;\n                        if (snippetText != null) {\n                            var texts = snippetText.split(' · ');\n                            if (texts != null && texts.length > 0) {\n                                data.open_group = texts[0]\n                                if (texts.length >= 1) {\n                                    data.member = texts[1];\n                                }\n                                if (texts.length >= 2) {\n                                    data.totalPosts = texts[2];\n                                }\n                            }\n                        }\n\n                    }\n\n                    data.keywords = spider.getSpiderParams(\"keywords\");\n                    var city = spider.getSpiderParams(\"city\");\n                    if (city && city != 'city') {\n                        data.city = city;\n                    }\n                    if (viewModel.profile && viewModel.profile.profile_picture\n                        && viewModel.profile.profile_picture.uri) {\n                        var avatarLarger = viewModel.profile.profile_picture.uri\n                        if (null != avatarLarger && avatarLarger != \"\") {\n                            var avatarBase = await getBase64FromUrl(avatarLarger);\n                            avatarLarger = spider.base64TOss(avatarBase);\n                        }\n                        data.avatarLarger = avatarLarger;\n                    }\n                    console.log(data)\n\n                    spider.postData(JSON.stringify(data));\n                }\n\n            });\n        }\n        else if (obj?.data?.rendering_strategy) {\n            var o = obj.data;\n            var data = {};\n            if (o.rendering_strategy && o.rendering_strategy.view_model) {\n                var viewModel = o.rendering_strategy.view_model;\n                data.username = viewModel.profile_name_with_possible_nickname;\n                if (viewModel.profile) {\n                    data.groupId = viewModel.profile.id;\n                    data.links = viewModel.profile.url;\n                }\n\n                if (viewModel.primary_snippet_text_with_entities != null) {\n                    var snippetText = viewModel.primary_snippet_text_with_entities.text;\n                    if (snippetText != null) {\n                        var texts = snippetText.split(' · ');\n                        if (texts != null && texts.length > 0) {\n                            data.open_group = texts[0]\n                            if (texts.length >= 1) {\n                                data.member = texts[1];\n                            }\n                            if (texts.length >= 2) {\n                                data.totalPosts = texts[2];\n                            }\n                        }\n                    }\n\n                }\n\n                data.keywords = spider.getSpiderParams(\"keywords\");\n                var city = spider.getSpiderParams(\"city\");\n                if (city && city != 'city') {\n                    data.city = city;\n                }\n                if (viewModel.profile && viewModel.profile.profile_picture\n                    && viewModel.profile.profile_picture.uri) {\n                    var avatarLarger = viewModel.profile.profile_picture.uri\n                    if (null != avatarLarger && avatarLarger != \"\") {\n                        var avatarBase = await getBase64FromUrl(avatarLarger);\n                        avatarLarger = spider.base64TOss(avatarBase);\n                    }\n                    data.avatarLarger = avatarLarger;\n                }\n                console.log(data)\n\n                spider.postData(JSON.stringify(data));\n            }\n\n        }\n    }\n    catch (error) {\n        console.error('Error parsing JSON:', error);\n    }\n})","id":22,"fields":[{"dpIndex":"1","code":"keywords","name":"关键词","type":"text"},{"dpIndex":"3","code":"username","name":"小组名称","type":"text"},{"dpIndex":"4","code":"avatarLarger","name":"头像","type":"image_url"},{"dpIndex":"5","code":"member","name":"成员","type":"text"},{"dpIndex":"6","code":"totalPosts","name":"帖子卷","type":"text"},{"dpIndex":"7","code":"links","name":"小组链接","type":"text"},{"dpIndex":"8","code":"date","name":"采集时间","type":"text"},{"dpIndex":"2","code":"city","name":"城市","type":"text"},{"dpIndex":"9","code":"open_group","name":"公开小组","type":"text"}],"spiderAppCode":"0","displayIndex":0,"injectionjs":"function checkListData(nums,count) {\n    window.scrollTo({\n        top: document.body.scrollHeight,\n        behavior: 'smooth'\n    });\n    var proFile = document.querySelectorAll('div[role=\"main\"]>div>div>div>div>div>div');\n    if (proFile == null || proFile.lenght == 0) {\n        console.log(\"没有数据啦\");\n        spider.endTask();\n    } else {\n        if (proFile.length != nums || (nums >= proFile.length && count != 5)) {\n\t\t\tif (nums >= proFile.length){\n\t\t\t\tcount++;\n\t\t\t}\n            var s = 'div[role=\"main\"]>div>div>div>div>div>div';\n            spider.toCheckDomDataWait(s, 20, function (flg) {\n                if (flg) {\n                    spider.toRunJsWaitTime(function () {\n\t\t\t\t\t\tconsole.log('proFile.length',proFile.length);\n                        checkListData(proFile.length,count);\n                    }, 5, 10);\n                } else {\n                    console.log(\"没有数据啦\");\n                    spider.endTask();\n\n                }\n            });\n        } else {\n\t\t\tconsole.log(\"没有数据啦\");\n        spider.endTask();\n\t\t}\n        \n    }\n}\n"}