{"code":"tiktok_peers_details_dsp","moduleCode":"tiktok","spiderParams":[{"dpIndex":"1","code":"keywords","name":"请输入TK用户名","type":"keyWords"}],"steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\nconsole.log(\"keywords\",keywords);","step":1},{"js":"window.location.href =  'https://www.tiktok.com/@'+ keywords;\n","step":"2"}],"homeUrl":"https://www.tiktok.com","hookurls":[{"path":"scripts","contains":"webapp.user-detail","callbackName":"jsfunction","callbackType":"jsfunc"}],"spiderMode":2,"name":"dsp_Tiktok同行详情挖掘","sipderJson":"obj = JSON.parse(inJsonStr);\n//console.log(obj);\nif (!IsFirstFlag && !obj[\"__DEFAULT_SCOPE__\"][\"webapp.user-detail\"].userInfo || obj[\"__DEFAULT_SCOPE__\"][\"webapp.user-detail\"].statusMsg == \"user banned\")\n    spider.endTask()\n\nif (IsFirstFlag && obj && obj[\"__DEFAULT_SCOPE__\"][\"webapp.user-detail\"].userInfo) {\n    IsFirstFlag = false;\n    console.log('userInfo', obj[\"__DEFAULT_SCOPE__\"][\"webapp.user-detail\"].userInfo);\n    data.keywords = spider.getSpiderParams(\"keywords\");\n    var userInfo = obj[\"__DEFAULT_SCOPE__\"][\"webapp.user-detail\"].userInfo;\n    if (userInfo.user.uniqueId) {\n        data.uniqueId = userInfo.user.uniqueId\n    }\n    if (userInfo.user.nickname) {\n        data.nickname = userInfo.user.nickname\n    }\n    if (userInfo.user.avatarLarger) {\n        var avatarBase = await getBase64FromUrl(userInfo.user.avatarLarger);\n        // data.cover = spider.base64TOss(avatarBase);\n        data.cover = userInfo.user.avatarLarger;\n        data.b64 = avatarBase;\n        if (data.b64) {\n            var taskId = mijava.doAddFaceDetect(data.b64, function (s, m) {\n                var ndata = JSON.parse(m);\n                var _taskid = ndata.taskId;\n                if (s == 1) {\n                    //成功\t  \n                    data.gender = ndata.gender  //性别\n\n                    ndata.age     //年龄\n                } else {\n                    //失败\n                    var msg = data.msg;\n                }\n            });\n        }\n    }\n    if (userInfo.user.id) {\n        data.id = userInfo.user.id\n    }\n\n    if (userInfo.stats) {\n        data.followingCount = userInfo.stats.followingCount\n        data.followerCount = userInfo.stats.followerCount\n        data.heart = userInfo.stats.heart\n        data.videoCount = userInfo.stats.videoCount\n        data.heartCount = userInfo.stats.heartCount\n    }\n    if (userInfo.user.secUid) {\n        data.secUid = userInfo.user.secUid\n    }\n    data.secUid = document.querySelector('h2[data-e2e=\"user-bio\"]').innerText;\n    setTimeout(() => {\n        console.log(\"Data \", data);\n        if (!data.gender) {\n            data.gender = \"无\"\n        }\n        spider.postData(JSON.stringify(data));\n    }, 2000);\n\n    // var tk_my_array = getArrayFromSessionStorage();\n    // var updatedArray = addObjectToArrayIfNotExists(tk_my_array, data);\n    // storeArrayToSessionStorage(updatedArray);\n\n    setTimeout(function () { spider.endTask(); }, 5000);\n}\n","id":238,"fields":[{"dpIndex":"1","code":"keywords","name":"用户名","type":"text"},{"dpIndex":"3","code":"nickname","name":"昵称","type":"text"},{"dpIndex":"4","code":"cover","name":"头像","type":"image_url"},{"dpIndex":"5","code":"id","name":"ID","type":"text"},{"dpIndex":"6","code":"followingCount","name":"关注","type":"int"},{"dpIndex":"7","code":"followerCount","name":"粉丝","type":"int"},{"dpIndex":"8","code":"heart","name":"红心","type":"int"},{"dpIndex":"9","code":"videoCount","name":"视频","type":"int"},{"dpIndex":"10","code":"heartCount","name":"获赞","type":"int"},{"dpIndex":"11","code":"secUid","name":"secUid","type":"text"},{"dpIndex":"12","code":"gender","name":"性别","type":"text"},{"dpIndex":"13","code":"date","name":"采集时间","type":"text"}],"spiderAppId":3,"spiderAppCode":"tiktok_peers_details","displayIndex":0,"injectionjs":"function getArrayFromSessionStorage() {\n    const storedArray = sessionStorage.getItem('tk_region_array');\n    return storedArray ? JSON.parse(storedArray) : [];\n}\n\nfunction addObjectToArrayIfNotExists(array, newObj) {\n    const isDuplicate = array.some(obj => obj.id === newObj.id);\n    if (!isDuplicate) {\n        array.push(newObj);\n        console.log(\"New object added:\", newObj);\n        spider.postData(JSON.stringify(newObj));\n    }\n    return array;\n}\n\nfunction storeArrayToSessionStorage(array) {\n    sessionStorage.setItem('tk_region_array', JSON.stringify(array));\n}\n\nfunction convertImgToBase64(url, format = 'image/png', quality = 0.92) {\n  return new Promise((resolve, reject) => {\n    const img = new Image();\n    img.crossOrigin = 'Anonymous'; // 处理跨域问题\n    img.src = url.includes('http') ? url : `${window.location.origin}${url}`;\n    \n    img.onload = () => {\n      const canvas = document.createElement('canvas');\n      canvas.width = img.naturalWidth;\n      canvas.height = img.naturalHeight;\n      const ctx = canvas.getContext('2d');\n      ctx.drawImage(img, 0, 0);\n      \n      try {\n        const base64 = canvas.toDataURL(format, quality);\n        resolve(base64);\n      } catch (e) {\n        reject(new Error('Canvas转换失败: ' + e.message));\n      }\n    };\n    \n    img.onerror = () => reject(new Error('图片加载失败'));\n  });\n}\n\nvar IsFirstFlag = true;\nvar data = {};\nvar obj ;"}