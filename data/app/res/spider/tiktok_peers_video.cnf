{"id":29,"code":"tiktok_peers_video","name":"Tiktok同行视频采集","sipderJson":"var obj = JSON.parse(inJsonStr);\n\nif (obj && obj.itemList) {\n    var userList = obj.itemList;\n\n    userList.forEach(async (o) => {\n        var data = {};\n        data.keywords = spider.getSpiderParams(\"keywords\");\n        if (o.desc) {\n            data.title = o.desc;\n        }\n        var videoUrl = \"https://www.tiktok.com/\";\n        if (o.author.uniqueId) {\n            videoUrl = videoUrl + \"@\" + o.author.uniqueId;\n        }\n        videoUrl = videoUrl + '/video/' + o.id;\n        data.videoUrl = videoUrl;\n        if (o.video.cover) {\n            var avatarBase = await getBase64FromUrl(o.video.cover);\n            data.cover = spider.base64TOss(avatarBase);\n\n        }\n        if (o.video.downloadAddr) {\n            data.downloadAddr = o.video.downloadAddr\n        }\n        if (o.video.duration) {\n            data.duration = o.video.duration\n        } else {\n            data.duration = \"无\";\n        }\n        if (o.video.format) {\n            data.format = o.video.format;\n        } else {\n            data.format = \"无\";\n        }\n\n        if (o.id) {\n            data.id = o.id;\n        }\n\n        if (o.stats) {\n            data.diggCount = o.stats.diggCount;\n            data.shareCount = o.stats.shareCount;\n            data.commentCount = o.stats.commentCount;\n            data.playCount = o.stats.playCount;\n        }\n        var tk_my_array = getArrayFromSessionStorage();\n        var updatedArray = addObjectToArrayIfNotExists(tk_my_array, data);\n        storeArrayToSessionStorage(updatedArray);\n\n    });\n}\n","homeUrl":"https://www.tiktok.com","hookurls":[{"path":"https://www.tiktok.com/api/post/item_list/","callbackType":"jsfunc","callbackName":"jsfunction","contains":"itemList"}],"injectionjs":"function getArrayFromSessionStorage() {\n    const storedArray = sessionStorage.getItem('tk_my_array_peers');\n    return storedArray ? JSON.parse(storedArray) : [];\n}\n\nfunction addObjectToArrayIfNotExists(array, newObj) {\n    const isDuplicate = array.some(obj => obj.id === newObj.id);\n    if (!isDuplicate) {\n        array.push(newObj);\n        spider.postData(JSON.stringify(newObj));\n    }\n    return array;\n}\n\nfunction storeArrayToSessionStorage(array) {\n    sessionStorage.setItem('tk_my_array_peers', JSON.stringify(array));\n}\n\n\nfunction checkListData(nums) {\n    window.scrollTo({\n        top: document.body.scrollHeight,\n        behavior: 'smooth'\n    });\n\n    var proFile = document.querySelectorAll('div[data-e2e=\"user-post-item-list\"]>div');\n    if (proFile == null || proFile.lenght == 0) {\n        console.log(\"没有数据啦1\");\n        spider.endTask();\n    }\n    else {\n        if (proFile.length != nums) {\n            var s = 'div[data-e2e=\"user-post-item-list\"]>div';\n            spider.toCheckDomDataWait(s, 60, function (flg) {\n                if (flg) {\n                    spider.toRunJsWaitTime(function () {\n                        console.log('proFile.length', proFile.length);\n                        checkListData(proFile.length);\n                    }, 4, 8);\n                } else {\n                    console.log(\"没有数据啦2\");\n                    spider.endTask();\n                }\n            });\n        }\n        else {\n            console.log(\"没有数据啦3\");\n            setTimeout(function () {spider.endTask(); }, 2000)\n            \n        }\n    }\n}","steps":[{"js":"var keywords = spider.getSpiderParams(\"keywords\");\n","step":1},{"js":"window.location.href = 'https://www.tiktok.com/@' + keywords;","step":"2"},{"js":"setTimeout(function(){checkListData(0);},7000)\n//spider.endTask();","step":"3"}],"displayIndex":0,"spiderParams":[{"code":"keywords","name":"请输入同行用户名","type":"keyWords","dpIndex":"1"}],"fields":[{"code":"keywords","name":"同行用户名","type":"text","dpIndex":"1"},{"code":"videoUrl","name":"视频链接","type":"text","dpIndex":"2"},{"dpIndex":"3","code":"title","name":"标题","type":"text"},{"dpIndex":"4","code":"cover","name":"封面","type":"image_url"},{"name":"时长","code":"duration","type":"int","dpIndex":"7"},{"name":"格式","code":"format","type":"int","dpIndex":"9"},{"code":"diggCount","name":"点赞数","type":"int","dpIndex":"10"},{"code":"shareCount","name":"分享数","type":"int","dpIndex":"11"},{"code":"commentCount","name":"评论数","type":"int","dpIndex":"12"},{"code":"playCount","name":"播放量","type":"int","dpIndex":"13"},{"code":"downloadAddr","name":"下载地址","type":"text","dpIndex":"14"},{"code":"date","name":"采集时间","type":"text","dpIndex":"8"}],"moduleCode":"tiktok","spiderMode":0,"spiderAppCode":"0"}